<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Activity Logs | <%= locals.SITE_NAME || 'Starworldz' %></title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --red: #e17055;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
    }

    .wrapper { display: flex; min-height: 100vh; }
    .main-content { margin-left: var(--sidebar-width); flex: 1; min-width: 0; }
    .content-body { padding: 28px; }

    .page-header { margin-bottom: 24px; }
    .page-title { font-size: 20px; font-weight: 800; }

    /* Tabs */
    .tabs-header {
      display: flex;
      gap: 8px;
      margin-bottom: 20px;
      background: #fff;
      padding: 6px;
      border-radius: 12px;
      border: 1px solid var(--card-border);
      width: fit-content;
    }

    .tab-btn {
      padding: 10px 20px;
      border: none;
      background: none;
      font-size: 13px;
      font-weight: 700;
      color: var(--text-muted);
      cursor: pointer;
      border-radius: 8px;
      transition: all 0.2s;
    }

    .tab-btn.active {
      background: var(--accent);
      color: #fff;
      box-shadow: 0 4px 12px rgba(108, 99, 255, 0.2);
    }

    .tab-pane { display: none; }
    .tab-pane.active { display: block; }

    .section-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    }

    .table-responsive { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 14px 20px; text-align: center; font-size: 11px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); }
    td { padding: 14px 20px; font-size: 13px; font-weight: 600; text-align: center; border-bottom: 1px solid #f8f9fb; }

    @media (max-width: 991px) { .main-content { margin-left: 0; } }
  </style>
</head>

<body>
  <div class="wrapper">
    <%- include('nav') %>
    <div class="main-content">
      <div class="content-body">
        <div class="page-header">
          <h2 class="page-title">Daily Activity Logs</h2>
          <p style="font-size: 13px; color: var(--text-muted);">Real-time tracking of team financial activities</p>
        </div>

        <div class="tabs-header">
          <button class="tab-btn active" data-tab="tab-recharge">RECHARGES</button>
          <button class="tab-btn" data-tab="tab-withdraw">WITHDRAWALS</button>
          <button class="tab-btn" data-tab="tab-gift">GIFT CARDS</button>
          <button class="tab-btn" data-tab="tab-adjust">ADJUSTMENTS</button>
        </div>

        <div class="tab-content">
          <div class="tab-pane active" id="tab-recharge">
            <div class="section-card">
              <div class="table-responsive">
                <table>
                  <thead><tr><th>Order ID</th><th>Account</th><th>Amount</th><th>Time</th></tr></thead>
                  <tbody id="list-recharge"></tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="tab-withdraw">
            <div class="section-card">
              <div class="table-responsive">
                <table>
                  <thead><tr><th>Order ID</th><th>Account</th><th>Amount</th><th>Time</th></tr></thead>
                  <tbody id="list-withdraw"></tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="tab-gift">
            <div class="section-card">
              <div class="table-responsive">
                <table>
                  <thead><tr><th>ID</th><th>Creator</th><th>Receiver</th><th>Amount</th><th>Time</th></tr></thead>
                  <tbody id="list-gift"></tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="tab-adjust">
            <div class="section-card">
              <div class="table-responsive">
                <table>
                  <thead><tr><th>ID</th><th>Type</th><th>Member</th><th>Amount</th><th>Time</th></tr></thead>
                  <tbody id="list-adjust"></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>
  <script>
    function timerJoin(params = '') {
      let date = params ? new Date(Number(params)) : new Date();
      return date.toLocaleString();
    }

    const loadLogs = () => {
      $.post("/manager/infoCtv", {}, function(res) {
        // Recharges
        let hRecharge = res.list_recharge_news.map(d => `<tr><td>#${d.id}</td><td style="color:var(--accent)">91${d.phone}</td><td style="color:var(--green)">₹${d.money}</td><td>${timerJoin(d.time)}</td></tr>`).join('');
        $('#list-recharge').html(hRecharge || '<tr><td colspan="4">No activity today</td></tr>');

        // Withdrawals
        let hWithdraw = res.list_withdraw_news.map(d => `<tr><td>#${d.id}</td><td style="color:var(--accent)">91${d.phone}</td><td style="color:var(--red)">₹${d.money}</td><td>${timerJoin(d.time)}</td></tr>`).join('');
        $('#list-withdraw').html(hWithdraw || '<tr><td colspan="4">No activity today</td></tr>');

        // Gifts
        let hGift = res.redenvelopes_used.map(d => `<tr><td>#${d.id_redenvelops}</td><td>91${d.phone}</td><td style="color:var(--accent)">91${d.phone_used}</td><td style="color:var(--green)">+₹${d.money}</td><td>${timerJoin(d.time)}</td></tr>`).join('');
        $('#list-gift').html(hGift || '<tr><td colspan="5">No history today</td></tr>');

        // Adjustments
        let hAdjust = res.financial_details_today.map(d => `<tr><td>#${d.id}</td><td>${d.type == '1' ? 'INCREASE' : 'DECREASE'}</td><td>91${d.phone_used}</td><td style="color:${d.type=='1'?'var(--green)':'var(--red)'}">${d.type=='1'?'+':'-'}₹${d.money}</td><td>${timerJoin(d.time)}</td></tr>`).join('');
        $('#list-adjust').html(hAdjust || '<tr><td colspan="5">No history today</td></tr>');
      });
    }

    $('.tab-btn').click(function() {
      $('.tab-btn').removeClass('active');
      $(this).addClass('active');
      $('.tab-pane').removeClass('active');
      $('#' + $(this).data('tab')).addClass('active');
    });

    loadLogs();
  </script>
</body>
</html>
