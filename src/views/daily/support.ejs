<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Support | <%= locals.SITE_NAME || 'Starworldz' %></title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --accent-light: rgba(108, 99, 255, 0.08);
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --red: #e17055;
      --yellow: #f1c40f;
      --blue: #3498db;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    .wrapper {
      display: flex;
      min-height: 100vh;
    }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
      min-width: 0;
    }

    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0;
      }
    }

    .topbar {
      background: var(--sidebar-bg);
      border-bottom: 1px solid var(--card-border);
      padding: 0 28px;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .topbar-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-primary);
    }

    .content-body {
      padding: 28px;
    }

    /* ── PAGE HEADER ── */
    .page-header {
      margin-bottom: 24px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .page-title {
      font-size: 20px;
      font-weight: 800;
      color: var(--text-primary);
    }

    .page-breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .page-breadcrumb span {
      color: var(--accent);
      font-weight: 600;
    }

    /* ── SUPPORT CARD ── */
    .section-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      margin: 0 auto;
      max-width: 600px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    }

    .section-header {
      padding: 24px;
      border-bottom: 1px solid var(--card-border);
      background: #fbfcfe;
    }

    .section-title {
      font-size: 16px;
      font-weight: 800;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-body {
      padding: 32px 24px;
      text-align: center;
    }

    .support-icon {
      width: 80px;
      height: 80px;
      background: var(--accent-light);
      color: var(--accent);
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      margin: 0 auto 24px;
    }

    .support-text {
      font-size: 15px;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 32px;
      line-height: 1.6;
    }

    .telegram-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      background: #0088cc;
      color: #fff;
      text-decoration: none;
      padding: 16px 24px;
      border-radius: 14px;
      font-size: 15px;
      font-weight: 800;
      transition: all 0.2s;
    }

    .telegram-btn:hover {
      background: #007bbd;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0, 136, 204, 0.2);
    }

    @media (max-width: 768px) {
      .content-body { padding: 16px; }
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <%- include('nav') %>

    <div class="main-content">
      <header class="topbar">
        <div class="topbar-title">Help & Support</div>
      </header>

      <div class="content-body">
        <div class="page-header">
          <div>
            <h2 class="page-title">Admin Support</h2>
            <div class="page-breadcrumb">Partner Panel &rsaquo; <span>Contact Us</span></div>
          </div>
        </div>

        <div class="section-card">
          <div class="section-header">
            <h3 class="section-title"><i class="fas fa-headset"></i> Need Assistance?</h3>
          </div>
          <div class="section-body">
            <div class="support-icon">
              <i class="fab fa-telegram-plane"></i>
            </div>
            <p class="support-text">
              If you have any questions, encounter technical issues, or need help managing your team, please contact the primary administrator via Telegram. We are here to support your growth.
            </p>

            <a href="#" id="telegram-link" class="telegram-btn" target="_blank">
              <i class="fab fa-telegram"></i> Message Administrator
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>

  <script>
    $.ajax({
      type: "POST",
      url: "/manager/settings/list",
      dataType: "json",
      success: function (response) {
        if(response.telegram) {
          $('#telegram-link').attr('href', response.telegram);
        }
      }
    });
  </script>
</body>

</html>