<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Partner Settings | <%= locals.SITE_NAME || 'Starworldz' %></title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --accent-light: rgba(108, 99, 255, 0.08);
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --red: #e17055;
      --yellow: #f1c40f;
      --blue: #3498db;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    .wrapper {
      display: flex;
      min-height: 100vh;
    }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
      min-width: 0;
    }

    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0;
        padding-top: 60px;
      }
      .content-body {
        padding: 16px;
      }
      .topbar {
        padding: 0 16px;
      }
      .topbar-title {
        font-size: 15px;
      }
    }

    .topbar {
      background: var(--sidebar-bg);
      border-bottom: 1px solid var(--card-border);
      padding: 0 28px;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .topbar-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-primary);
    }

    .content-body {
      padding: 28px;
    }

    /* ── PAGE HEADER ── */
    .page-header {
      margin-bottom: 24px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .page-title {
      font-size: 20px;
      font-weight: 800;
      color: var(--text-primary);
    }

    .page-breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .page-breadcrumb span {
      color: var(--accent);
      font-weight: 600;
    }

    /* ── SETTINGS CARD ── */
    .section-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      margin: 0 auto;
      max-width: 600px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    }

    .section-header {
      padding: 24px;
      border-bottom: 1px solid var(--card-border);
      background: #fbfcfe;
    }

    .section-title {
      font-size: 16px;
      font-weight: 800;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-body {
      padding: 24px;
    }

    .form-group {
      margin-bottom: 24px;
    }

    .form-label {
      display: block;
      font-size: 13px;
      font-weight: 700;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .form-input {
      width: 100%;
      background: #f7f8fc;
      border: 1px solid var(--card-border);
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      outline: none;
      transition: all 0.2s;
    }

    .form-input:focus {
      border-color: var(--accent);
      background: #fff;
      box-shadow: 0 0 0 4px var(--accent-light);
    }

    .form-help {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 8px;
      line-height: 1.4;
    }

    .btn-submit {
      width: 100%;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 12px;
      padding: 14px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn-submit:hover {
      background: #5a52e6;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(108, 99, 255, 0.2);
    }

    @media (max-width: 768px) {
      .content-body { padding: 16px; }
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <%- include('nav') %>

    <div class="main-content">
      <header class="topbar">
        <div class="topbar-title">Account Settings</div>
      </header>

      <div class="content-body">
        <div class="page-header">
          <div>
            <h2 class="page-title">Profile Settings</h2>
            <div class="page-breadcrumb">Partner Panel &rsaquo; <span>Preferences</span></div>
          </div>
        </div>

        <div class="section-card">
          <div class="section-header">
            <h3 class="section-title"><i class="fab fa-telegram" style="color: #0088cc;"></i> Contact Information</h3>
          </div>
          <div class="section-body">
            <div class="form-group">
              <label class="form-label" for="telegram">Support Telegram Link</label>
              <input type="text" id="telegram" class="form-input" placeholder="e.g. https://t.me/yourusername">
              <p class="form-help">This Telegram link will be displayed to your members as your official customer support contact.</p>
            </div>

            <button type="button" class="btn-submit telegram">
              <i class="fas fa-save"></i> Save Settings
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    // Initial Load
    $.ajax({
      type: "POST",
      url: "/manager/settings/list",
      dataType: "json",
      success: function (response) {
        $('#telegram').val(response.telegram2);
      }
    });

    // Save Settings
    $('.telegram').click(function (e) {
      e.preventDefault();
      let value = $('#telegram').val().trim();
      
      if (value) {
        $.ajax({
          type: "POST",
          url: "/manager/settings/list",
          data: {
            type: 'edit',
            value: value,
          },
          dataType: "json",
          success: function (response) {
            Swal.fire({
              icon: response.status ? 'success' : 'error',
              title: response.status ? 'Saved!' : 'Error',
              text: response.message,
              confirmButtonColor: '#6c63ff',
              timer: 2000
            });
          }
        });
      } else {
        Swal.fire({
          icon: 'warning',
          title: 'Empty Field',
          text: 'Please enter a valid Telegram link.',
          confirmButtonColor: '#6c63ff'
        });
      }
    });
  </script>
</body>

</html>