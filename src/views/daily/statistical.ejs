<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Partner Dashboard | <%= locals.SITE_NAME || 'Starworldz' %></title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --accent-light: rgba(108, 99, 255, 0.08);
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --red: #e17055;
      --yellow: #f1c40f;
      --blue: #3498db;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    .wrapper {
      display: flex;
      min-height: 100vh;
    }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
      min-width: 0;
    }

    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0;
        padding-top: 60px;
      }
      .content-body {
        padding: 16px;
      }
      .topbar {
        padding: 0 16px;
      }
      .topbar-title {
        font-size: 15px;
      }
    }

    .topbar {
      background: var(--sidebar-bg);
      border-bottom: 1px solid var(--card-border);
      padding: 0 28px;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .topbar-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-primary);
    }

    .content-body {
      padding: 28px;
    }

    /* ── PAGE HEADER ── */
    .page-header {
      margin-bottom: 24px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .page-title {
      font-size: 20px;
      font-weight: 800;
      color: var(--text-primary);
    }

    .page-breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .page-breadcrumb span {
      color: var(--accent);
      font-weight: 600;
    }

    /* ── STATS GRID ── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
      margin-bottom: 28px;
    }

    @media (max-width: 575.98px) {
      .stats-grid {
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .stat-card {
        padding: 16px;
      }
      .page-title {
        font-size: 20px;
      }
    }

    .stat-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 20px;
      padding: 20px;
      display: flex;
      align-items: center;
      gap: 16px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
      transition: transform 0.2s;
    }

    .stat-card:hover {
      transform: translateY(-4px);
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }

    .icon-blue { background: rgba(52, 152, 219, 0.1); color: var(--blue); }
    .icon-green { background: rgba(0, 184, 148, 0.1); color: var(--green); }
    .icon-red { background: rgba(225, 112, 85, 0.1); color: var(--red); }
    .icon-yellow { background: rgba(241, 196, 15, 0.1); color: var(--yellow); }
    .icon-purple { background: var(--accent-light); color: var(--accent); }

    .stat-info {
      display: flex;
      flex-direction: column;
    }

    .stat-label {
      font-size: 12px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 18px;
      font-weight: 800;
      color: var(--text-primary);
      margin-top: 2px;
    }

    /* ── TOOLBAR / FILTER ── */
    .toolbar {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 16px;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 28px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    }

    .filter-label {
      font-size: 13px;
      font-weight: 700;
      color: var(--text-secondary);
    }

    .date-input {
      background: #f7f8fc;
      border: 1px solid var(--card-border);
      border-radius: 10px;
      padding: 8px 12px;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
      outline: none;
      transition: all 0.2s;
    }

    .date-input:focus {
      border-color: var(--accent);
      background: #fff;
    }

    /* ── SECTION CARDS ── */
    .section-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      margin-bottom: 28px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    }

    .section-header {
      padding: 20px 24px;
      border-bottom: 1px solid var(--card-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #fbfcfe;
    }

    .section-title {
      font-size: 15px;
      font-weight: 800;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* ── TABLES ── */
    .table-responsive {
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead th {
      padding: 14px 20px;
      text-align: center;
      font-size: 11px;
      font-weight: 800;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      border-bottom: 1px solid var(--card-border);
    }

    tbody tr {
      border-bottom: 1px solid #f8f9fb;
      transition: background 0.2s;
    }

    tbody tr:hover {
      background: rgba(108, 99, 255, 0.01);
    }

    td {
      padding: 14px 20px;
      font-size: 13px;
      font-weight: 600;
      text-align: center;
      vertical-align: middle;
    }

    .badge {
      padding: 4px 10px;
      border-radius: 8px;
      font-size: 11px;
      font-weight: 700;
    }

    .bg-success-light { background: rgba(0, 184, 148, 0.1); color: var(--green); }
    .bg-warning-light { background: rgba(241, 196, 15, 0.1); color: var(--yellow); }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .content-body { padding: 16px; }
      .stats-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
      .stat-card { padding: 14px; gap: 12px; }
      .stat-icon { width: 40px; height: 40px; font-size: 16px; }
      .stat-value { font-size: 15px; }
      .section-card { border-radius: 16px; }
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <%- include('nav') %>

    <div class="main-content">
      <header class="topbar">
        <div class="topbar-title">Partner Panel Dashboard</div>
      </header>

      <div class="content-body">
        <div class="page-header">
          <div>
            <h2 class="page-title">Welcome Back, Partner</h2>
            <div class="page-breadcrumb">Manager &rsaquo; <span>Overview</span></div>
          </div>
          <div id="ip_address" style="font-size: 12px; font-weight: 700; color: var(--text-muted); background: #eee; padding: 4px 12px; border-radius: 20px;">IP Address: Loading...</div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon icon-blue"><i class="fas fa-users"></i></div>
            <div class="stat-info">
              <span class="stat-label">Total Members</span>
              <span class="stat-value totalMember">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-purple"><i class="fas fa-dice"></i></div>
            <div class="stat-info">
              <span class="stat-label">Bet Today</span>
              <span class="stat-value betToday">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-purple"><i class="fas fa-coins"></i></div>
            <div class="stat-info">
              <span class="stat-label">Total Bet (Life)</span>
              <span class="stat-value totalBet">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-green"><i class="fas fa-hand-holding-usd"></i></div>
            <div class="stat-info">
              <span class="stat-label">Win Today</span>
              <span class="stat-value totalWin text-success">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-green"><i class="fas fa-trophy"></i></div>
            <div class="stat-info">
              <span class="stat-label">Total Win (Life)</span>
              <span class="stat-value lifeWin text-success">₹0</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon icon-green"><i class="fas fa-arrow-up"></i></div>
            <div class="stat-info">
              <span class="stat-label">Total Deposits</span>
              <span class="stat-value totalRecharge text-success">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-green"><i class="fas fa-calendar-day"></i></div>
            <div class="stat-info">
              <span class="stat-label">Deposits Today</span>
              <span class="stat-value totalRechargeToday">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-yellow"><i class="fas fa-arrow-down"></i></div>
            <div class="stat-info">
              <span class="stat-label">Total Withdrawals</span>
              <span class="stat-value totalwithdraw text-warning">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-yellow"><i class="fas fa-calendar-minus"></i></div>
            <div class="stat-info">
              <span class="stat-label">Withdraws Today</span>
              <span class="stat-value totalwithdrawToday">₹0</span>
            </div>
          </div>

        </div>


        <!-- Giftcode Section -->
        <div class="stat-card" style="margin-bottom: 28px; border-left: 4px solid var(--accent);">
          <div class="stat-icon icon-purple"><i class="fas fa-gift"></i></div>
          <div class="stat-info">
            <span class="stat-label">Giftcode Creation Balance</span>
            <span class="stat-value moneyCTV" style="color: var(--accent); font-size: 22px;">₹0</span>
            <span style="font-size: 11px; color: var(--text-muted); font-weight: 600; margin-top: 2px;">Funds available to generate giftcodes for your team</span>
          </div>
        </div>

        <!-- Tables Section -->
        <div class="section-card">
          <div class="section-header">
            <h3 class="section-title"><i class="fas fa-user-plus" style="color: var(--blue);"></i> Recent Registrations</h3>
          </div>
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>User ID</th>
                  <th>Account</th>
                  <th>Inviter</th>
                  <th>Balance</th>
                  <th>Status</th>
                  <th>IP Address</th>
                  <th>Join Time</th>
                </tr>
              </thead>
              <tbody id="list-mem-news"></tbody>
            </table>
          </div>
        </div>


      </div>
    </div>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    function formateT(params) {
      return (params < 10) ? "0" + params : params;
    }

    function timerJoin(params = '', addHours = 0) {
      let date = params ? new Date(Number(params)) : new Date();
      date.setHours(date.getHours() + addHours);
      let years = formateT(date.getFullYear());
      let months = formateT(date.getMonth() + 1);
      let days = formateT(date.getDate());
      let hours = date.getHours() % 12;
      hours = hours === 0 ? 12 : hours;
      let ampm = date.getHours() < 12 ? "AM" : "PM";
      let minutes = formateT(date.getMinutes());
      let seconds = formateT(date.getSeconds());
      return `${years}/${months}/${days} ${hours}:${minutes}:${seconds} ${ampm}`;
    }

    const RenderMemberNews = (datas) => {
      let html = datas.length === 0 ? '<tr><td colspan="7" style="padding: 30px; color: var(--text-muted);">No new members found.</td></tr>' : '';
      datas.forEach((data) => {
        html += `
          <tr>
            <td>#${data.id_user}</td>
            <td style="color: var(--accent); font-weight: 700;">91${data.phone}</td>
            <td style="color: var(--text-muted);">${data.phone_invite ? '91' + data.phone_invite : 'Direct'}</td>
            <td style="color: var(--red); font-weight: 800;">₹${Number(data.money).toFixed(2)}</td>
            <td><span class="badge ${data.money > 0 ? 'bg-success-light' : 'bg-warning-light'}">${data.money > 0 ? 'ACTIVE' : 'NEW'}</span></td>
            <td style="font-size: 11px; color: var(--text-muted);">${data.ip_address}</td>
            <td style="font-size: 11px;">${timerJoin(data.time)}</td>
          </tr>`;
      });
      $("#list-mem-news").html(html);
    }


    const loadData = (timeDate = null) => {
      const url = timeDate ? "/manager/infoCtv/select" : "/manager/infoCtv";
      const data = timeDate ? { timeDate: timeDate } : {};

      $.ajax({
        type: "POST",
        url: url,
        data: data,
        dataType: "json",
        success: function (response) {
          RenderMemberNews(response.list_mems);

          if (!timeDate) {
            $('.totalMember').text(response.total_team);
            $('#ip_address').text('IP Address: ' + response.datas[0].ip_address);
            $('.totalRecharge').text('₹' + Number(response.total_recharge).toFixed(2));
            $('.totalwithdraw').text('₹' + Number(response.total_withdraw).toFixed(2));
            $('.totalRechargeToday').text('₹' + Number(response.total_recharge_today).toFixed(2));
            $('.totalwithdrawToday').text('₹' + Number(response.total_withdraw_today).toFixed(2));
            $('.betToday').text('₹' + Number(response.bet_today).toFixed(2));
            $('.totalBet').text('₹' + Number(response.total_bet).toFixed(2));
            $('.totalWin').text('₹' + Number(response.win_today).toFixed(2));
            $('.lifeWin').text('₹' + Number(response.total_win).toFixed(2));
            $('.moneyCTV').text('₹' + Number(response.moneyCTV).toFixed(2));
          }
        }
      });
    }


    loadData();
  </script>
</body>

</html>