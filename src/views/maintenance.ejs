<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Under Maintenance | Starworldz</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #6366f1;
            --accent: #f59e0b;
            --bg: #0f172a;
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            color: #f8fafc;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
        }

        .bg-animate {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 50% 50%, #1e293b 0%, #0f172a 100%);
            z-index: -1;
        }

        .circle {
            position: absolute;
            border-radius: 50%;
            background: var(--primary);
            filter: blur(100px);
            opacity: 0.15;
            z-index: -1;
            animation: move 20s infinite alternate;
        }

        @keyframes move {
            0% {
                transform: translate(-10%, -10%);
            }

            100% {
                transform: translate(10%, 10%);
            }
        }

        .container {
            max-width: 500px;
            width: 90%;
            text-align: center;
            padding: 40px;
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 30px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .icon-box {
            width: 80px;
            height: 80px;
            background: rgba(99, 102, 241, 0.1);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            color: var(--primary);
            font-size: 32px;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% {
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.4);
            }

            70% {
                transform: scale(1.05);
                box-shadow: 0 0 0 15px rgba(99, 102, 241, 0);
            }

            100% {
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(99, 102, 241, 0);
            }
        }

        h1 {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }

        p {
            font-size: 14px;
            color: #94a3b8;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        .timer-section {
            padding-top: 25px;
            border-top: 1px solid var(--glass-border);
        }

        .timer-label {
            font-size: 10px;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--accent);
            letter-spacing: 2px;
            margin-bottom: 15px;
        }

        .timer-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
        }

        .timer-item {
            background: rgba(255, 255, 255, 0.05);
            padding: 15px 10px;
            border-radius: 15px;
            border: 1px solid var(--glass-border);
        }

        .timer-val {
            font-size: 24px;
            font-weight: 800;
            display: block;
        }

        .timer-unit {
            font-size: 9px;
            color: #64748b;
            text-transform: uppercase;
            font-weight: 600;
            margin-top: 4px;
        }

        .footer-note {
            margin-top: 30px;
            font-size: 12px;
            color: #475569;
        }
    </style>
</head>

<body>
    <div class="bg-animate"></div>
    <div class="circle" style="width: 400px; height: 400px; top: -100px; right: -100px;"></div>
    <div class="circle" style="width: 300px; height: 300px; bottom: -50px; left: -50px; background: #818cf8;"></div>

    <div class="container">
        <div class="icon-box">
            <i class="fas fa-tools"></i>
        </div>
        <h1>Maintenance Mode</h1>
        <p>We are currently upgrading our servers to provide you with a faster and more secure experience. We'll be back
            shortly.</p>

        <div class="timer-section">
            <% if (endTime) { %>
                <div class="timer-label">Estimated System Restart</div>
                <div class="timer-grid">
                    <div class="timer-item">
                        <span class="timer-val" id="h">00</span>
                        <span class="timer-unit">Hours</span>
                    </div>
                    <div class="timer-item">
                        <span class="timer-val" id="m">00</span>
                        <span class="timer-unit">Minutes</span>
                    </div>
                    <div class="timer-item">
                        <span class="timer-val" id="s">00</span>
                        <span class="timer-unit">Seconds</span>
                    </div>
                </div>
                <script>
                    const target = new Date("<%= endTime %>").getTime();
                    function update() {
                        const now = new Date().getTime();
                        const diff = target - now;
                        if (diff < 0) {
                            document.querySelectorAll('.timer-val').forEach(e => e.innerText = "00");
                            window.location.href = '/home'; return;
                        }
                        const hrs = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                        const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                        const secs = Math.floor((diff % (1000 * 60)) / 1000);
                        document.getElementById('h').innerText = hrs.toString().padStart(2, '0');
                        document.getElementById('m').innerText = mins.toString().padStart(2, '0');
                        document.getElementById('s').innerText = secs.toString().padStart(2, '0');
                    }
                    setInterval(update, 1000); update();
                </script>
                <% } else { %>
                    <p style="color: var(--accent); font-weight: 600; font-size: 14px;">System will be back online very
                        soon.</p>
                    <% } %>
        </div>

        <div class="footer-note">
            &copy; 2026 Starworldz. Stay tuned.
        </div>
    </div>

    <script>
        setTimeout(() => window.location.reload(), 30000);
    </script>
</body>

</html>