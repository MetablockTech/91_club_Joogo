<div class="table-container">
    <div class="table-responsive">
        <table class="modern-table">
            <thead>
                <tr>
                    <th>Stage</th>
                    <th>Game</th>
                    <th>Amount</th>
                    <th>Choice</th>
                    <th>Outcome</th>
                    <th>Extra Info</th>
                    <th>Status</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody id="list-bet">
                <tr><td colspan="8" class="text-center text-muted">Loading bet data...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="pagination-wrap">
        <button class="page-link-btn" id="previousBet">Previous</button>
        <button class="page-link-btn active" id="text-bet">1</button>
        <button class="page-link-btn" id="nextBet">Next</button>
    </div>
</div>