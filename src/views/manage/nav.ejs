<!-- Global Plugins -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const mobileToggle = document.getElementById('mobileToggle');
    const customSidebar = document.getElementById('customSidebar');
    const sidebarOverlay = document.getElementById('sidebarOverlay');

    function toggleSidebar() {
      customSidebar.classList.toggle('sidebar-open');
      sidebarOverlay.classList.toggle('sidebar-open');
    }

    mobileToggle.addEventListener('click', toggleSidebar);
    sidebarOverlay.addEventListener('click', toggleSidebar);

    // Collapsible Bet History Logic
    const betHistoryToggle = document.getElementById('betHistoryToggle');
    const betHistorySubmenu = document.getElementById('betHistorySubmenu');

    if (betHistoryToggle) {
      betHistoryToggle.addEventListener('click', function() {
        this.classList.toggle('open');
        betHistorySubmenu.classList.toggle('active');
      });
    }

    // Active Link Highlighting based on URL
    const currentPath = window.location.pathname;
    document.querySelectorAll('.sidebar-nav-item').forEach(link => {
      if (link.getAttribute('href') === currentPath) {
        link.classList.add('active');
        
        // If it's a submenu item, also open the parent
        const parentSubmenu = link.closest('.sidebar-submenu');
        if (parentSubmenu) {
          parentSubmenu.classList.add('active');
          const toggle = parentSubmenu.previousElementSibling;
          if (toggle) toggle.classList.add('open');
        }
      }
    });
  });

  // Global Toast Implementation
  window.alertMsg = (title, icon = 'success') => {
    if (typeof Swal !== 'undefined') {
      Swal.fire({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
        icon: icon,
        title: title,
        background: '#fff',
        customClass: {
          popup: 'premium-toast-popup-standard',
        }
      });
    } else {
      console.log(`Alert [${icon}]: ${title}`);
    }
  };
</script>