<script>
    const RenderRecharge = (datas) => {
        if (!datas || datas.length == 0) {
            $('#list-recharge').html(`<tr><td colspan="5" class="text-center text-muted">no data...</td></tr>`);
            return;
        }
        let html = '';
        datas.map((data) => {
            html += `
            <tr>
                <td style="color: var(--accent3); font-weight: 600;">${data.id_order}</td>
                <td><b style="color: var(--accent)">${(data.money)}</b></td>
                <td><b>${(data.type == "bank") ? "BANK" : "UPI"}</b></td>
                <td><span class="status-badge ${(data.status == '1' ? 'status-success' : 'status-warning')}">${(data.status == '1' ? 'Success' : 'Pending')}</span></td>
                <td>${timerJoin(data.time)}</td>
            </tr>`;
        });
        $("#list-recharge").html(html);
    }

    var pageno1 = 0;
    var limit1 = 15;
    var page1 = 1;
    
    function loadRecharge() {
        $.ajax({
            type: "POST",
            url: "/admin/member/listRecharge/" + phone,
            data: { typeid: "1", pageno: pageno1, limit: limit1, language: "vi" },
            dataType: "json",
            success: function (response) {
                $('#text-recharge').text(page1 + ' / ' + (response?.page_total || 1));
                if (response?.status === true) return RenderRecharge(response?.datas);
            }
        });
    }

    loadRecharge();

    $('#nextRecharge').click(function (e) {
        e.preventDefault();
        pageno1 += limit1;
        $.ajax({
            type: "POST",
            url: "/admin/member/listRecharge/" + phone,
            data: { typeid: "1", pageno: pageno1, limit: limit1, language: "vi" },
            dataType: "json",
            success: function (response) {
                if (response?.datas.length == 0) {
                    $('#nextRecharge').addClass('block-click');
                    pageno1 -= limit1;
                    return;
                }
                $('#text-recharge').text(++page1 + ' / ' + response?.page_total);
                if (response?.status === true) return RenderRecharge(response?.datas);
            }
        });
    });

    $('#previousRecharge').click(function (e) {
        e.preventDefault();
        $('#nextRecharge').removeClass('block-click');
        pageno1 -= limit1;
        if (pageno1 < 0) pageno1 = 0;
        else page1--;
        
        $.ajax({
            type: "POST",
            url: "/admin/member/listRecharge/" + phone,
            data: { typeid: "1", pageno: pageno1, limit: limit1, language: "vi" },
            dataType: "json",
            success: function (response) {
                $('#text-recharge').text(page1 + ' / ' + response?.page_total);
                if (response?.status === true) return RenderRecharge(response?.datas);
            }
        });
    });
</script>
