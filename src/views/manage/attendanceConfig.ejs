<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Attendance Settings | <%= locals.SITE_NAME || 'Starworldz' %> Admin</title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@600&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --accent-light: rgba(108, 99, 255, 0.08);
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --blue: #3498db;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    .wrapper { display: flex; min-height: 100vh; }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1; display: flex; flex-direction: column; transition: all 0.3s; min-width: 0;
    }

    @media (max-width: 991.98px) { .main-content { margin-left: 0; } }

    .topbar {
      background: var(--sidebar-bg); border-bottom: 1px solid var(--card-border);
      padding: 0 28px; height: 70px; display: flex; align-items: center; justify-content: space-between;
      z-index: 50;
    }
    .topbar-title { font-size: 18px; font-weight: 700; color: var(--text-primary); }

    .content-body { padding: 28px; }

    /* ── TOOLBAR ── */
    .toolbar {
      background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 20px;
      padding: 20px 24px; margin-bottom: 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }
    .toolbar h2 { font-size: 20px; font-weight: 800; color: var(--text-primary); }
    .toolbar p { font-size: 13px; color: var(--text-muted); margin-top: 4px; }

    /* ── TABLE ── */
    .table-card {
      background: #fff; border: 1px solid var(--card-border); border-radius: 24px;
      overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }
    .table-responsive { overflow-x: auto; width: 100%; }
    table { width: 100%; border-collapse: collapse; min-width: 800px; }
    thead th {
      background: #fbfcfe; padding: 18px 20px; text-align: center;
      font-size: 11px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px;
      border-bottom: 1px solid var(--card-border);
    }
    tbody tr { border-bottom: 1px solid #f8f9fb; transition: background 0.2s; }
    tbody tr:hover { background: rgba(108, 99, 255, 0.02); }
    td { padding: 15px; vertical-align: middle; }

    .day-badge {
      padding: 6px 12px; border-radius: 8px; background: var(--accent-light);
      color: var(--accent); font-weight: 800; font-size: 12px;
      display: inline-flex; align-items: center; justify-content: center;
    }

    .inp-threshold {
      width: 150px; height: 42px; border-radius: 10px; border: 1.5px solid var(--card-border);
      text-align: center; font-family: 'JetBrains Mono', monospace; font-weight: 700;
      font-size: 14px; background: #f9fbfd; transition: all 0.2s; outline: none;
    }
    .inp-threshold:focus { border-color: var(--accent); background: #fff; box-shadow: 0 0 0 4px var(--accent-light); }

    .btn-update {
      height: 40px; padding: 0 18px; border-radius: 10px; border: none; background: var(--accent);
      color: #fff; cursor: pointer; transition: all 0.2s; font-size: 13px; font-weight: 700;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-update:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(108, 99, 255, 0.25); }
    
    .status-text { font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; }

    /* ── RESPONSIVE OVERRIDES ── */
    @media (max-width: 991.98px) {
      .main-content { margin-left: 0; padding-top: 60px !important; }
      .topbar { display: none !important; }
    }

    @media (max-width: 768px) {
      .content-body { padding: 12px !important; }
      .toolbar { padding: 15px; text-align: center; border-radius: 12px; margin-bottom: 15px; }
      .toolbar h2 { font-size: 18px; }
      
      .table-card { border-radius: 12px; }
      .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      table { min-width: 800px; } 
      
      .btn-update { width: 100%; justify-content: center; padding: 10px; }
    }
  </style>
</head>
<body>

  <div class="wrapper">
    <%- include('nav') %>

    <div class="main-content">
      <header class="topbar">
        <div class="topbar-title">Configuration &rsaquo; Attendance Rewards</div>
      </header>

      <div class="content-body">
        
        <div class="toolbar">
          <h2>Attendance Reward Settings</h2>
          <p>Define the bonus amounts and total recharge requirements for the 7-day attendance program.</p>
        </div>

        <div class="table-card">
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th class="text-center">Check-in Day</th>
                  <th class="text-center">Required Today's Recharge (₹)</th>
                  <th class="text-center">Bonus Amount (₹)</th>
                  <th class="text-center">Actions</th>
                </tr>
              </thead>
              <tbody id="attendance-body">
                <!-- Data injected via JS -->
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/dist/js/adminlte.min.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    function alertMsg(text, icon = "success") {
      Swal.fire({
        text: text,
        icon: icon,
        confirmButtonText: "OK",
      });
    }

    function loadConfig() {
      $.ajax({
        type: "GET",
        url: "/api/webapi/admin/getAttendanceConfig",
        dataType: "json",
        success: function (response) {
          if (response.status && response.rows.length > 0) {
            let html = "";
            response.rows.forEach(function (item) {
              html += `<tr>
                <td class="text-center">
                  <div class="day-badge">Day ${item.day}</div>
                </td>
                <td class="text-center">
                  <input type="number" name="required_recharge" value="${item.required_recharge}" class="inp-threshold">
                </td>
                <td class="text-center">
                  <input type="number" name="bonus_amount" value="${item.bonus_amount}" class="inp-threshold">
                </td>
                <td class="text-center">
                  <button class="btn-update confirm-btn" data-id="${item.id}"><i class="fa-solid fa-arrows-rotate"></i> Update Day ${item.day}</button>
                </td>
              </tr>`;
            });
            $('#attendance-body').html(html);
          }
        }
      });
    }

    $(document).ready(function() {
      loadConfig();

      $('#attendance-body').on('click', '.confirm-btn', function (e) {
        e.preventDefault();
        const row = $(this).closest('tr');
        const id = $(this).data('id');
        const data = {
          id: id,
          required_recharge: row.find('input[name="required_recharge"]').val(),
          bonus_amount: row.find('input[name="bonus_amount"]').val()
        };

        $.ajax({
          type: "POST",
          url: "/api/webapi/admin/updateAttendanceConfig",
          dataType: "json",
          data: data,
          success: function (response) {
            if(response.status) {
                alertMsg('Attendance settings updated for Day ' + (row.index() + 1));
            } else {
                alertMsg(response.message, 'error');
            }
          },
          error: function () {
            alertMsg('Failed to update attendance config.', 'error');
          }
        });
      });
    });
  </script>
</body>
</html>
