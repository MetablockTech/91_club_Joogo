<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Giftcode Issuance | <%= locals.SITE_NAME || 'Starworldz' %> Admin</title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@600&display=swap');

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --accent-light: rgba(108, 99, 255, 0.08);
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --red: #e17055;
      --blue: #3498db;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    .wrapper {
      display: flex;
      min-height: 100vh;
    }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
      min-width: 0;
    }

    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0;
      }
    }

    .topbar {
      background: var(--sidebar-bg);
      border-bottom: 1px solid var(--card-border);
      padding: 0 28px;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .topbar-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-primary);
    }

    .content-body {
      padding: 28px;
    }

    /* ── FORM CARD ── */
    .form-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      padding: 30px;
      margin-bottom: 28px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 24px;
      align-items: flex-end;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .form-group.full-width {
      grid-column: 1 / -1;
    }

    .form-group label {
      font-size: 11px;
      font-weight: 800;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .inp-control {
      height: 50px;
      border-radius: 14px;
      border: 1.5px solid var(--card-border);
      padding: 0 18px;
      font-size: 14px;
      font-weight: 600;
      outline: none;
      transition: all 0.2s;
      background: #f9fbfd;
    }

    .inp-control:focus {
      border-color: var(--accent);
      background: #fff;
      box-shadow: 0 0 0 4px var(--accent-light);
    }

    .checkbox-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 50px;
      border-radius: 14px;
      border: 1.5px solid var(--card-border);
      padding: 0 18px;
      background: #f9fbfd;
      transition: all 0.2s;
      cursor: pointer;
    }

    .checkbox-wrap:hover {
      border-color: var(--accent-light);
    }

    .checkbox-wrap input {
      width: 18px;
      height: 18px;
      cursor: pointer;
      accent-color: var(--accent);
    }

    .result-wrap {
      margin-top: 25px;
      padding: 20px;
      border-radius: 16px;
      background: var(--accent-light);
      border: 1px dashed var(--accent);
      display: none;
      align-items: center;
      gap: 15px;
    }

    .result-inp {
      flex: 1;
      background: #fff;
      border: 1px solid var(--card-border);
      border-radius: 10px;
      height: 44px;
      padding: 0 15px;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 800;
      color: var(--accent);
    }

    .btn-copy {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: var(--accent);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
    }

    .btn-copy:hover {
      transform: scale(1.05);
      box-shadow: 0 5px 15px rgba(108, 99, 255, 0.3);
    }

    .btn-submit {
      height: 50px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 14px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .btn-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(108, 99, 255, 0.3);
    }

    /* ── TABLE CARD ── */
    .table-card {
      background: #fff;
      border: 1px solid var(--card-border);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    }

    .table-responsive {
      overflow-x: auto;
      width: 100%;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 1000px;
    }

    thead th {
      background: #fbfcfe;
      padding: 18px 20px;
      text-align: left;
      font-size: 11px;
      font-weight: 800;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      border-bottom: 1px solid var(--card-border);
    }

    tbody tr {
      border-bottom: 1px solid #f8f9fb;
      transition: background 0.2s;
    }

    tbody tr:hover {
      background: rgba(108, 99, 255, 0.02);
    }

    td {
      padding: 15px 20px;
      font-size: 14px;
      font-weight: 500;
      vertical-align: middle;
    }

    .badge {
      padding: 6px 12px;
      border-radius: 30px;
      font-size: 11px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid transparent;
    }

    .badge-yes {
      background: rgba(0, 184, 148, 0.1);
      color: var(--green);
    }

    .badge-no {
      background: rgba(225, 112, 85, 0.1);
      color: var(--red);
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
    }

    .mono {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      font-weight: 600;
    }

    .amount {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 800;
      color: var(--green);
      font-size: 15px;
    }

    /* ── RESPONSIVE OVERRIDES ── */
    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0;
        padding-top: 60px !important;
      }

      .topbar {
        padding: 0 16px;
      }
    }

    @media (max-width: 768px) {
      .content-body {
        padding: 16px;
      }

      .form-card {
        padding: 20px;
        border-radius: 18px;
      }

      .form-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .btn-submit {
        width: 100%;
      }

      .result-wrap {
        flex-direction: column;
        align-items: stretch;
        text-align: center;
      }

      .table-card {
        border-radius: 18px;
      }

      .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      table {
        min-width: 1000px;
      }
    }
  </style>
</head>

<body>

  <div class="wrapper">
    <%- include('nav') %>

      <div class="main-content">
        <header class="topbar">
          <div class="topbar-title">Financial Tools &rsaquo; Giftcode Issuance</div>
        </header>

        <div class="content-body">

          <div class="form-card">
            <div style="margin-bottom: 25px;">
              <h2 style="font-size: 20px; font-weight: 800; color: var(--text-primary);">Create New Giftcode</h2>
              <p style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">Generate universal redemption codes
                for marketing campaigns and rewards.</p>
            </div>

            <form id="rewardForm" class="form-grid">
              <div class="form-group">
                <label>Redeemable Amount (₹)</label>
                <input type="text" class="inp-control" id="money" placeholder="e.g. 500"
                  oninput="value=value.replace(/\D/g,'')">
              </div>
              <div class="form-group">
                <label>Max Redemption Limit</label>
                <input type="number" class="inp-control" id="user" placeholder="Number of users">
              </div>

              <div class="form-group">
                <label>New Users Only</label>
                <div class="checkbox-wrap" onclick="$(this).find('input').click()">
                  <span style="font-size: 13px; font-weight: 600; color: var(--text-secondary);">Restrict to first-time
                    users</span>
                  <input type="checkbox" id="isForNewUsers" onclick="event.stopPropagation()">
                </div>
              </div>

              <div class="form-group">
                <label>Set Expiration</label>
                <div class="checkbox-wrap" onclick="$(this).find('#expiry_date_check').click()">
                  <span style="font-size: 13px; font-weight: 600; color: var(--text-secondary);">Enable time
                    limit</span>
                  <input type="checkbox" id="expiry_date_check" onclick="event.stopPropagation()">
                </div>
              </div>

              <div class="form-group" id="expiry_wrap" style="display: none;">
                <label>Expiry Timestamp</label>
                <input type="datetime-local" class="inp-control" id="expiry_date">
              </div>

              <button type="submit" class="btn-submit" id="submit">
                <i class="fas fa-magic"></i> Generate Verified Giftcode
              </button>
            </form>

            <div class="result-wrap" id="resultBlock">
              <span
                style="font-size: 12px; font-weight: 800; color: var(--accent); text-transform: uppercase;">Generated
                Code:</span>
              <input type="text" class="result-inp" id="money_result" readonly>
              <button class="btn-copy" id="copyLink" title="Copy to Clipboard">
                <i class="fa fa-clone"></i>
              </button>
            </div>
          </div>

          <div class="table-card">
            <header style="padding: 20px 28px; border-bottom: 1px solid var(--card-border);">
              <h3 style="font-size: 16px; font-weight: 800; color: var(--text-primary);">Unused Giftcodes Ledger</h3>
            </header>
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th>Issuance ID</th>
                    <th>Creator</th>
                    <th>Value</th>
                    <th>Quota</th>
                    <th>New Users</th>
                    <th>Auto Expiry</th>
                    <th>Issuance Time</th>
                  </tr>
                </thead>
                <tbody id="list-details-news">
                  <!-- Data injected via JS -->
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </div>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="/lib/moment.min.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    function timerJoin(params = '') {
      let date = params ? new Date(Number(params)) : new Date();
      let f = (n) => n < 10 ? '0' + n : n;
      return `${date.getFullYear()}/${f(date.getMonth() + 1)}/${f(date.getDate())} ${f(date.getHours())}:${f(date.getMinutes())}`;
    }

    const RenderHistory = (datas) => {
      if (datas.length == 0) {
        $('#list-details-news').html('<tr><td colspan="7" style="text-align:center; padding: 40px; color: var(--text-muted);">No active giftcodes found. Create one above!</td></tr>');
        return;
      }
      let html = '';
      datas.forEach((data) => {
        html += `
          <tr>
            <td class="mono" style="color: var(--text-muted);">#${data.id_redenvelope}</td>
            <td><div style="font-weight: 700; color: var(--accent);">91${data.phone}</div></td>
            <td class="amount">₹${data.money}</td>
            <td class="mono">${data.used} Users</td>
            <td>
              <span class="badge ${data.for_new_users == 1 ? 'badge-yes' : 'badge-no'}">
                <span class="dot"></span> ${data.for_new_users == 1 ? 'Restricted' : 'Universal'}
              </span>
            </td>
            <td style="font-size: 12px; font-weight: 700; color: var(--text-secondary);">
              ${data.expire_date !== "0" ? '<i class="far fa-clock" style="margin-right:5px;"></i>' + timerJoin(data.expire_date) : 'Infinite'}
            </td>
            <td style="font-size: 12px; font-weight: 600; color: var(--text-muted);">${timerJoin(data.time)}</td>
          </tr>
        `;
      });
      $("#list-details-news").html(html);
    };

    const fetchHistory = () => {
      $.ajax({
        type: "GET",
        url: "/admin/manager/listRedenvelops",
        success: (res) => RenderHistory(res.redenvelopes)
      });
    };

    $('#expiry_date_check').change(function () {
      $('#expiry_wrap').toggle(this.checked);
    });

    $('#copyLink').click(function () {
      navigator.clipboard.writeText($('#money_result').val());
      alertMsg('Giftcode copied to clipboard.');
    });

    $('#submit').click(function (e) {
      e.preventDefault();
      const money = $('#money').val().trim();
      const numberOfUsers = $('#user').val();
      const isForNewUsers = $('#isForNewUsers').prop('checked') ? 1 : 0;
      const expiryCheck = $('#expiry_date_check').prop('checked');
      const expiryValue = $('#expiry_date').val();

      if (!money) return alertMsg('Please enter a reward amount.', 'warning');

      if (expiryCheck && moment(expiryValue).valueOf() <= Date.now()) {
        return alertMsg('Expiration must be in the future!', 'warning');
      }

      $.ajax({
        type: "POST",
        url: "/admin/manager/createBonus",
        data: {
          money: money,
          numberOfUsers: numberOfUsers,
          isForNewUsers: isForNewUsers,
          expireDate: expiryCheck ? moment(expiryValue).format("DD/MM/YYYY HH:mm:ss") : undefined
        },
        success: function (res) {
          if (res.status) {
            $('#money_result').val(res.id);
            $('#resultBlock').css('display', 'flex');
            alertMsg('Giftcode has been successfully generated.');
            fetchHistory();
          }
        }
      });
    });

    fetchHistory();
  </script>
</body>

</html>