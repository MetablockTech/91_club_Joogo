<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Withdrawal Requests | <%= locals.SITE_NAME || 'Starworldz' %> Admin</title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@600&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --accent-light: rgba(108, 99, 255, 0.08);
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --red: #e17055;
      --blue: #3498db;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    .wrapper { display: flex; min-height: 100vh; }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1; display: flex; flex-direction: column; transition: all 0.3s; min-width: 0;
    }

    @media (max-width: 991.98px) { .main-content { margin-left: 0; } }

    .topbar {
      background: var(--sidebar-bg); border-bottom: 1px solid var(--card-border);
      padding: 0 28px; height: 70px; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 50;
    }
    .topbar-title { font-size: 18px; font-weight: 700; color: var(--text-primary); }

    .content-body { padding: 28px; }

    /* ── TABS ── */
    .toolbar {
      background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 20px;
      padding: 16px 20px; display: flex; align-items: center; gap: 16px; margin-bottom: 28px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }
    .tab-group {
      display: flex; background: #f0f2f8; padding: 4px; border-radius: 14px; gap: 4px;
    }
    .tab-btn {
      padding: 10px 24px; border-radius: 10px; font-size: 13px; font-weight: 700;
      cursor: pointer; transition: all 0.2s; border: none; outline: none;
      color: var(--text-secondary); background: transparent;
    }
    .tab-btn.active { background: #fff; color: var(--accent); box-shadow: 0 2px 8px rgba(0,0,0,0.05); }

    /* ── TABLE ── */
    .table-card {
      background: #fff; border: 1px solid var(--card-border); border-radius: 24px;
      overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }
    .table-responsive { overflow-x: auto; width: 100%; }
    table { width: 100%; border-collapse: collapse; min-width: 1200px; }
    thead th {
      background: #fbfcfe; padding: 16px 20px; text-align: left;
      font-size: 11px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;
      border-bottom: 1px solid var(--card-border);
    }
    tbody tr { border-bottom: 1px solid #f8f9fb; transition: background 0.2s; }
    tbody tr:hover { background: rgba(108, 99, 255, 0.02); }
    td { padding: 16px 20px; font-size: 14px; font-weight: 500; vertical-align: middle; }

    .badge {
      padding: 6px 12px; border-radius: 30px; font-size: 11px; font-weight: 700;
      display: inline-flex; align-items: center; gap: 6px; border: 1px solid transparent;
    }
    .badge-waiting { background: rgba(241, 196, 15, 0.1); color: #f39c12; }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

    .amount-cell { font-family: 'JetBrains Mono', monospace; font-weight: 800; color: var(--text-primary); font-size: 15px; }
    .mono { font-family: 'JetBrains Mono', monospace; font-size: 12px; }

    .btn-action {
      width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center;
      border: none; cursor: pointer; transition: all 0.2s;
    }
    .btn-approve { background: rgba(0, 184, 148, 0.1); color: var(--green); }
    .btn-approve:hover { background: var(--green); color: #fff; }
    .btn-reject { background: rgba(225, 112, 85, 0.1); color: var(--red); }
    .btn-reject:hover { background: var(--red); color: #fff; }

    /* ── POPUP ── */
    .popup-overlay {
      position: fixed; inset: 0; background: rgba(26, 29, 46, 0.6); backdrop-filter: blur(8px);
      z-index: 2000; display: none; align-items: center; justify-content: center; padding: 20px;
    }
    .popup-overlay.active { display: flex; }
    .popup-content {
      background: #fff; width: 100%; max-width: 480px; border-radius: 28px;
      padding: 35px; box-shadow: 0 25px 70px rgba(0,0,0,0.2);
    }
    .popup-header h3 { font-size: 20px; font-weight: 800; color: var(--text-primary); }
    .popup-header p { font-size: 14px; color: var(--text-secondary); margin-top: 8px; line-height: 1.5; }
    .popup-header b { color: var(--accent); }

    .form-group { margin: 25px 0; }
    .form-group label { display: block; font-size: 12px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; margin-bottom: 10px; }
    .form-group textarea {
      width: 100%; height: 100px; border-radius: 16px; border: 1.5px solid var(--card-border);
      padding: 15px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; outline: none;
      transition: all 0.2s; background: #f9fafb; resize: none;
    }
    .form-group textarea:focus { border-color: var(--accent); background: #fff; box-shadow: 0 0 0 4px var(--accent-light); }

    .popup-footer { display: flex; gap: 12px; }
    .popup-btn {
      flex: 1; height: 52px; border-radius: 16px; font-size: 14px; font-weight: 700;
      cursor: pointer; transition: all 0.2s; border: none;
    }
    .btn-cancel { background: #f0f2f8; color: var(--text-secondary); }
    .btn-cancel:hover { background: #e3e7f0; }
    .btn-submit { background: var(--accent); color: #fff; box-shadow: 0 8px 20px rgba(108, 99, 255, 0.25); }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(108, 99, 255, 0.35); }

    /* ── RESPONSIVE OVERRIDES ── */
    @media (max-width: 991.98px) {
      .main-content { margin-left: 0; padding-top: 60px !important; }
      .topbar { padding: 0 16px; height: 60px; }
    }

    @media (max-width: 768px) {
      .content-body { padding: 12px !important; }
      .toolbar { padding: 16px; border-radius: 15px; margin-bottom: 20px; flex-direction: column; }
      .tab-group { flex-direction: column; width: 100%; }
      .tab-btn { width: 100%; text-align: center; }
      
      .table-card { border-radius: 15px; }
      .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      table { min-width: 1200px; } 
      
      .popup-content { padding: 24px; border-radius: 20px; }
      .popup-footer { flex-direction: column; }
    }
    
    /* Breadcrumb styling */
    .page-header { margin-bottom: 24px; }
    .page-title { font-size: 20px; font-weight: 800; color: var(--text-primary); }
    .page-breadcrumb { font-size: 13px; color: var(--text-muted); margin-top: 4px; }
    .page-breadcrumb span { color: var(--accent); font-weight: 600; }
  </style>
</head>
<body>

  <div class="wrapper">
    <%- include('nav') %>

    <div class="main-content">
      <header class="topbar">
        <div class="topbar-title">Finance &rsaquo; Withdrawal Requests</div>
      </header>

      <div class="content-body">
        
        <div class="toolbar">
          <div class="tab-group">
            <button class="tab-btn active" data-type="BANK_CARD">Bank Transfer</button>
            <button class="tab-btn" data-type="UPI">UPI</button>
            <button class="tab-btn" data-type="USDT_ADDRESS">USDT Crypto</button>
          </div>
          <div style="flex: 1;"></div>
          <button class="tab-btn" style="background: var(--accent); color:#fff; padding: 10px 20px" onclick="initTableData()">
            <i class="fas fa-sync-alt" style="margin-right: 8px;"></i> Sync Queue
          </button>
        </div>

        <div class="table-card">
          <div class="table-responsive">
            <table id="withdrawal-table">
              <thead id="table-head">
                <!-- Head injected based on tab -->
              </thead>
              <tbody id="table-body">
                <!-- Data injected via JS -->
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Action Modal -->
  <div class="popup-overlay" id="popupRoot">
    <div class="popup-content">
      <div class="popup-header">
        <h3>Confirm Action</h3>
        <p>Reviewing withdrawal request for <b id="phoneLabel">---</b>. Please provide remarks if necessary.</p>
      </div>
      <div class="form-group">
        <label>Moderation Remarks</label>
        <textarea id="remarksField" placeholder="Enter reason for approval or rejection..."></textarea>
      </div>
      <div class="form-group" id="payoutMethodGroup">
        <label>Payout Routing (For Approval)</label>
        <select id="payoutMethod" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid var(--card-border); outline: none; font-family: 'Inter', sans-serif;">
          <option value="AUTO">Auto (Gateway / Payok)</option>
          <option value="MANUAL">Manual (Local Transfer)</option>
        </select>
      </div>
      <div class="popup-footer">
        <button class="popup-btn btn-cancel" id="cancelBtn">Close</button>
        <button class="popup-btn btn-submit" id="submitBtn">Submit Decision</button>
      </div>
    </div>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.7.2/axios.min.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    const WITHDRAWAL_METHODS = { BANK_CARD: "BANK_CARD", USDT_ADDRESS: "USDT_ADDRESS", UPI_ID: "UPI" };
    const WITHDRAWAL_STATUS = { PENDING: 0, APPROVED: 1, DENIED: 2 };
    
    let activeTab = WITHDRAWAL_METHODS.BANK_CARD;
    let currentId = null;
    let currentStatus = null;

    function alertMsg(msg, icon = 'success') {
      Swal.fire({
        text: msg,
        icon: icon,
        confirmButtonText: 'OK',
        customClass: {
          confirmButton: 'btn-submit',
          popup: 'popup-content'
        }
      });
    }

    function formateT(params) {
      let result = (params < 10) ? "0" + params : params;
      return result;
    }

    function timerJoin(params = '') {
      let date = params ? new Date(Number(params)) : new Date();
      let years = formateT(date.getFullYear());
      let months = formateT(date.getMonth() + 1);
      let days = formateT(date.getDate());
      let hours = date.getHours();
      let minutes = formateT(date.getMinutes());
      let ampm = hours >= 12 ? 'PM' : 'AM';
      hours = hours % 12 || 12;
      return `${years}/${months}/${days} ${formateT(hours)}:${minutes} ${ampm}`;
    }

    const renderTable = (list) => {
      let headHtml = "";
      let bodyHtml = "";

      if (activeTab === WITHDRAWAL_METHODS.BANK_CARD) {
        headHtml = `
          <tr>
            <th>ID</th>
            <th>Account</th>
            <th>Bank Details</th>
            <th>Recipient</th>
            <th>AC Number</th>
            <th>IFSC</th>
            <th>Amount (INR)</th>
            <th>Request Time</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        `;
        const items = list.filter(i => i.type === WITHDRAWAL_METHODS.BANK_CARD);
        if (items.length === 0) {
          bodyHtml = '<tr><td colspan="10" style="text-align:center; padding: 40px;">No bank withdrawals pending.</td></tr>';
        } else {
          items.forEach(data => {
            bodyHtml += `
              <tr>
                <td style="font-weight: 800; color: var(--text-muted);">#${data.id}</td>
                <td><div style="font-weight: 700; color: var(--accent);">91${data.phoneNumber}</div></td>
                <td><div style="font-weight: 700;">${data.bankName}</div></td>
                <td><div style="font-weight: 600; color: var(--text-secondary);">${data.recipientName}</div></td>
                <td class="mono">${data.bankAccountNumber || '---'}</td>
                <td class="mono" style="color: var(--text-muted); font-size: 11px;">${data.IFSC || '---'}</td>
                <td class="amount-cell">₹${data.amount}</td>
                <td style="font-size: 12px; white-space: nowrap;">${timerJoin(data.time)}</td>
                <td><span class="badge badge-waiting"><span class="dot"></span> Pending</span></td>
                <td>
                  <div style="display: flex; gap: 8px;">
                    <button class="btn-action btn-approve" onclick="openPopup(${data.id}, '91${data.phoneNumber}', ${WITHDRAWAL_STATUS.APPROVED})"><i class="fa fa-check"></i></button>
                    <button class="btn-action btn-reject" onclick="openPopup(${data.id}, '91${data.phoneNumber}', ${WITHDRAWAL_STATUS.DENIED})"><i class="fa fa-times"></i></button>
                  </div>
                </td>
              </tr>
            `;
          });
        }
      } else if (activeTab === WITHDRAWAL_METHODS.UPI_ID) {
        headHtml = `
          <tr>
            <th>ID</th>
            <th>Account</th>
            <th>UPI ID</th>
            <th>Amount (INR)</th>
            <th>Request Time</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        `;
        const items = list.filter(i => i.type === WITHDRAWAL_METHODS.UPI_ID);
        if (items.length === 0) {
          bodyHtml = '<tr><td colspan="7" style="text-align:center; padding: 40px;">No UPI withdrawals pending.</td></tr>';
        } else {
          items.forEach(data => {
            bodyHtml += `
              <tr>
                <td style="font-weight: 800; color: var(--text-muted);">#${data.id}</td>
                <td><div style="font-weight: 700; color: var(--accent);">91${data.phoneNumber}</div></td>
                <td><div class="badge" style="background:var(--accent-light); color:var(--accent); font-family: 'JetBrains Mono', monospace;">${data.upiId}</div></td>
                <td class="amount-cell">₹${data.amount}</td>
                <td style="font-size: 12px; white-space: nowrap;">${timerJoin(data.time)}</td>
                <td><span class="badge badge-waiting"><span class="dot"></span> Pending</span></td>
                <td>
                  <div style="display: flex; gap: 8px;">
                    <button class="btn-action btn-approve" onclick="openPopup(${data.id}, '91${data.phoneNumber}', ${WITHDRAWAL_STATUS.APPROVED})"><i class="fa fa-check"></i></button>
                    <button class="btn-action btn-reject" onclick="openPopup(${data.id}, '91${data.phoneNumber}', ${WITHDRAWAL_STATUS.DENIED})"><i class="fa fa-times"></i></button>
                  </div>
                </td>
              </tr>
            `;
          });
        }
      } else {
        headHtml = `
          <tr>
            <th>ID</th>
            <th>Account</th>
            <th>Network</th>
            <th>USDT Address</th>
            <th>USDT Rate</th>
            <th>USDT Amount</th>
            <th>Amount (INR)</th>
            <th>Time</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        `;
        const items = list.filter(i => i.type === WITHDRAWAL_METHODS.USDT_ADDRESS);
        if (items.length === 0) {
          bodyHtml = '<tr><td colspan="10" style="text-align:center; padding: 40px;">No crypto withdrawals pending.</td></tr>';
        } else {
          items.forEach(data => {
            bodyHtml += `
              <tr>
                <td style="font-weight: 800; color: var(--text-muted);">#${data.id}</td>
                <td><div style="font-weight: 700; color: var(--accent);">91${data.phoneNumber}</div></td>
                <td><div class="badge" style="background:#e8f4fd; color:#2980b9;">${data.mainNetwork || 'TRC20'}</div></td>
                <td class="mono" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;">${data.usdtAddress}</td>
                <td class="mono" style="color: var(--red); font-weight: 700;">₹${data.usdtRate || '---'}</td>
                <td class="mono" style="color: var(--green); font-weight: 800;">${data.usdtAmount ? parseFloat(data.usdtAmount).toFixed(4) : '---'} <small>USDT</small></td>
                <td class="amount-cell">₹${data.amount}</td>
                <td style="font-size: 12px; white-space: nowrap;">${timerJoin(data.time)}</td>
                <td><span class="badge badge-waiting"><span class="dot"></span> Pending</span></td>
                <td>
                  <div style="display: flex; gap: 8px;">
                    <button class="btn-action btn-approve" onclick="openPopup(${data.id}, '91${data.phoneNumber}', ${WITHDRAWAL_STATUS.APPROVED})"><i class="fa fa-check"></i></button>
                    <button class="btn-action btn-reject" onclick="openPopup(${data.id}, '91${data.phoneNumber}', ${WITHDRAWAL_STATUS.DENIED})"><i class="fa fa-times"></i></button>
                  </div>
                </td>
              </tr>
            `;
          });
        }
      }

      $("#table-head").html(headHtml);
      $("#table-body").html(bodyHtml);
    };

    async function initTableData() {
      try {
        const response = await axios.get("/api/webapi/withdraw/pending");
        renderTable(response.data.withdrawList);
      } catch (error) {
        console.error("Failed to fetch withdrawals:", error);
      }
    }

    window.openPopup = (id, phone, status) => {
      currentId = id;
      currentStatus = status;
      $("#phoneLabel").text(phone);
      $("#remarksField").val("");
      if (status == 1 && activeTab === WITHDRAWAL_METHODS.BANK_CARD) {
        $("#payoutMethodGroup").show();
      } else {
        $("#payoutMethodGroup").hide();
      }
      $("#popupRoot").addClass("active");
    };

    $("#cancelBtn").click(() => $("#popupRoot").removeClass("active"));

    $("#submitBtn").click(async function() {
      const btn = $(this);
      if (btn.prop("disabled")) return;

      btn.prop("disabled", true).text("Processing...").css("opacity", "0.6");
      try {
        const response = await axios({
          method: "POST",
          url: "/api/webapi/admin/withdraw/status",
          data: {
            id: currentId,
            status: currentStatus,
            remarks: $("#remarksField").val(),
            payoutMethod: activeTab === WITHDRAWAL_METHODS.BANK_CARD ? $("#payoutMethod").val() : "MANUAL"
          }
        });
        $("#popupRoot").removeClass("active");
        alertMsg(response.data.message);
        initTableData();
      } catch (error) {
        alertMsg(error.response?.data?.message || "An error occurred", 'error');
      } finally {
        btn.prop("disabled", false).text("Submit Decision").css("opacity", "1");
      }
    });

    $(".tab-btn").click(function() {
      $(".tab-btn").removeClass("active");
      $(this).addClass("active");
      activeTab = $(this).data("type");
      initTableData();
    });

    initTableData();
    setInterval(initTableData, 45000); // Check every 45s
  </script>
</body>
</html>