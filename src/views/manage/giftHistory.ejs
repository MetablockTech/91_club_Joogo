<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giftcode History | Admin Panel</title>
    <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

        :root {
            --bg: #f0f2f8;
            --sidebar-bg: #ffffff;
            --card-bg: #ffffff;
            --card-border: #e3e7f0;
            --accent: #6c63ff;
            --text-primary: #1a1d2e;
            --text-secondary: #5a5f7a;
            --text-muted: #9ea3b8;
            --green: #00b894;
            --red: #e17055;
            --sidebar-width: 260px;
        }

        body {
            font-family: 'Inter', sans-serif !important;
            background: var(--bg);
            color: var(--text-primary);
            overflow-x: hidden;
        }

        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
            transition: all 0.3s;
        }

        @media (max-width: 991.98px) {
            .main-content {
                margin-left: 0;
                padding-top: 60px;
            }
        }

        .topbar {
            background: var(--sidebar-bg);
            border-bottom: 1px solid var(--card-border);
            padding: 0 28px;
            height: 70px;
            display: flex;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-title {
            font-size: 18px;
            font-weight: 700;
        }

        .content-body {
            padding: 28px;
        }

        /* ── FILTER CARD ── */
        .filter-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 24px;
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: flex-end;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
            flex: 1;
            min-width: 180px;
        }

        .filter-group label {
            font-size: 11px;
            font-weight: 800;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        .filter-group input {
            padding: 10px 14px;
            border: 1px solid var(--card-border);
            border-radius: 10px;
            font-size: 14px;
            background: #fbfcfe;
            transition: border-color 0.2s;
        }

        .filter-group input:focus {
            outline: none;
            border-color: var(--accent);
        }

        .btn-search {
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 700;
            cursor: pointer;
            height: 42px;
            transition: opacity 0.2s;
        }

        .btn-search:hover {
            opacity: 0.9;
        }

        /* ── TABLE SECTION ── */
        .section-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 900px;
        }

        thead th {
            padding: 18px 20px;
            text-align: center;
            font-size: 11px;
            font-weight: 800;
            color: var(--text-muted);
            text-transform: uppercase;
            background: #fafbfc;
            border-bottom: 1px solid var(--card-border);
            letter-spacing: 0.8px;
        }

        tbody td {
            padding: 16px 20px;
            font-size: 13px;
            font-weight: 600;
            text-align: center;
            border-bottom: 1px solid #f8f9fb;
        }

        .code-badge {
            font-family: monospace;
            background: #f0f2f8;
            padding: 4px 8px;
            border-radius: 6px;
            color: var(--text-primary);
            font-size: 12px;
        }

        .phone-link {
            color: var(--accent);
            text-decoration: none;
            font-weight: 700;
        }

        /* ── PAGINATION ── */
        .pagination-wrap {
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            background: #fafbfc;
            border-top: 1px solid var(--card-border);
        }

        .pag-btn {
            background: #fff;
            border: 1px solid var(--card-border);
            padding: 10px 20px;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--text-secondary);
        }

        .pag-btn:hover:not(.disabled) {
            border-color: var(--accent);
            color: var(--accent);
        }

        .pag-btn.disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .pag-info {
            font-size: 14px;
            font-weight: 800;
            background: #f0f2f8;
            padding: 8px 18px;
            border-radius: 10px;
            min-width: 80px;
            text-align: center;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include('nav') %>
        <div class="main-content">
            <header class="topbar">
                <div class="topbar-title">Financial Audit &rsaquo; Giftcode History</div>
            </header>
            <div class="content-body">
                <div class="filter-card">
                    <div class="filter-group">
                        <label>Search Phone/Code</label>
                        <input type="text" id="filter-phone" placeholder="91782...">
                    </div>
                    <div class="filter-group">
                        <label>Start Date</label>
                        <input type="date" id="filter-start">
                    </div>
                    <div class="filter-group">
                        <label>End Date</label>
                        <input type="date" id="filter-end">
                    </div>
                    <button class="btn-search" id="btn-search"><i class="fas fa-search"></i> Filter</button>
                </div>

                <div class="section-card">
                    <div class="table-responsive">
                        <table>
                            <thead>
                                <tr>
                                    <th>Gift Code</th>
                                    <th>Creator</th>
                                    <th>Receiver</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Redeemed At</th>
                                </tr>
                            </thead>
                            <tbody id="table-body">
                                <tr>
                                    <td colspan="6" style="padding: 40px; color: var(--text-muted);">Loading historical data...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination-wrap">
                        <button class="pag-btn" id="prev-btn">Previous</button>
                        <span class="pag-info" id="pag-info">1 / 1</span>
                        <button class="pag-btn" id="next-btn">Next</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/plugins/jquery/jquery.min.js"></script>
    <script>
        function timerJoin(params = '') {
            let date = params ? new Date(Number(params)) : new Date();
            if(isNaN(date.getTime())) date = new Date(params);
            
            let Y = date.getFullYear();
            let M = (date.getMonth() + 1).toString().padStart(2, '0');
            let D = date.getDate().toString().padStart(2, '0');
            let h = date.getHours() % 12 || 12;
            let m = date.getMinutes().toString().padStart(2, '0');
            let s = date.getSeconds().toString().padStart(2, '0');
            let ampm = date.getHours() >= 12 ? 'PM' : 'AM';
            return `${Y}-${M}-${D} ${h}:${m}:${s} ${ampm}`;
        }

        let pageno = 0,
            limit = 20,
            page = 1,
            totalPages = 1;

        function loadData() {
            const data = {
                pageno: pageno,
                limit: limit,
                phone: $('#filter-phone').val(),
                startDate: $('#filter-start').val(),
                endDate: $('#filter-end').val()
            };

            $.ajax({
                type: "POST",
                url: "/api/webapi/admin/listGiftHistory",
                data: data,
                success: function(res) {
                    if (!res.status) return;
                    totalPages = res.page_total || 1;
                    $('#pag-info').text(`${page} / ${totalPages}`);
                    
                    let html = '';
                    if (res.datas.length === 0) {
                        html = '<tr><td colspan="6" style="padding: 40px; color: var(--text-muted);">No records found matching your criteria.</td></tr>';
                    } else {
                        html = res.datas.map(d => `
                            <tr>
                                <td><span class="code-badge">${d.id_redenvelops}</span></td>
                                <td><a href="/admin/member/info/${d.phone}" class="phone-link">91${d.phone}</a></td>
                                <td><a href="/admin/member/info/${d.phone_used}" class="phone-link">91${d.phone_used}</a></td>
                                <td style="color: var(--green); font-weight: 800;">₹${Number(d.money).toFixed(2)}</td>
                                <td><span style="color: var(--green); background: rgba(0,184,148,0.1); padding: 4px 10px; border-radius: 6px; font-size: 12px;">SUCCESS</span></td>
                                <td style="font-size: 12px; opacity: 0.8;">${timerJoin(d.time)}</td>
                            </tr>
                        `).join('');
                    }
                    $("#table-body").html(html);

                    $('#prev-btn').toggleClass('disabled', page <= 1);
                    $('#next-btn').toggleClass('disabled', page >= totalPages);
                }
            });
        }

        $('#btn-search').click(() => {
            pageno = 0;
            page = 1;
            loadData();
        });
        $('#next-btn').click(() => {
            if (page < totalPages) {
                pageno += limit;
                page++;
                loadData();
            }
        });
        $('#prev-btn').click(() => {
            if (page > 1) {
                pageno -= limit;
                page--;
                loadData();
            }
        });

        loadData();
    </script>
</body>

</html>
