<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Commission Reports | <%= locals.SITE_NAME || 'Admin' %></title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --accent-light: rgba(108, 99, 255, 0.08);
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --red: #e17055;
      --blue: #2d6cdf;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
    }

    .wrapper {
      display: flex;
      min-height: 100vh;
    }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
      min-width: 0;
      width: 100%;
    }

    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0;
      }
    }

    .topbar {
      background: var(--sidebar-bg);
      border-bottom: 1px solid var(--card-border);
      padding: 0 28px;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
      width: 100%;
    }

    .content-body {
      padding: 28px;
      width: 100%;
    }

    .page-header {
      margin-bottom: 28px;
    }

    .page-title {
      font-size: 24px;
      font-weight: 800;
      color: var(--text-primary);
      letter-spacing: -0.5px;
    }

    .page-breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 6px;
    }

    .page-breadcrumb span {
      color: var(--accent);
      font-weight: 600;
    }

    /* TOOLBAR & FILTERS */
    .toolbar {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 18px;
      padding: 20px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    }

    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .filter-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .filter-input {
      background: #f7f8fc;
      border: 1px solid var(--card-border);
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
      outline: none;
      transition: all 0.2s;
    }

    .filter-input:focus {
      border-color: var(--accent);
      background: #fff;
    }

    .btn-search {
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 10px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: all 0.2s;
      align-self: flex-end;
      height: 42px;
    }

    .btn-search:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    /* TABLE */
    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .table-header {
      padding: 18px 24px;
      background: #fff;
      border-bottom: 1px solid var(--card-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .table-header h3 {
      font-size: 16px;
      font-weight: 700;
    }

    .table-responsive {
      overflow-x: auto;
      width: 100%;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 1000px;
    }

    thead th {
      padding: 14px 20px;
      font-size: 11px;
      font-weight: 800;
      color: var(--text-muted);
      text-transform: uppercase;
      text-align: left;
      background: #fdfdfe;
      border-bottom: 2px solid #f0f2f8;
    }

    tbody tr {
      border-bottom: 1px solid #f0f2f8;
      transition: all 0.2s;
    }

    tbody tr:hover {
      background: rgba(108, 99, 255, 0.02);
    }

    td {
      padding: 16px 20px;
      font-size: 14px;
    }

    .commission-val {
      font-weight: 800;
      color: var(--blue);
    }

    .level-badge {
      background: var(--accent-light);
      color: var(--accent);
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 700;
    }

    /* PAGINATION */
    .pagination-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 24px;
      border-top: 1px solid #f0f2f8;
    }

    .pagination-btns {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .page-btn {
      width: 34px;
      height: 34px;
      border: 1.5px solid var(--card-border);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 13px;
      font-weight: 700;
      transition: all 0.2s;
    }

    .page-btn.active {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    .page-btn.disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* STATS GRID */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 28px;
    }

    .stat-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 18px;
      padding: 20px;
      display: flex;
      align-items: center;
      gap: 18px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
      transition: all 0.3s;
    }

    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.06);
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }

    .stat-info {
      display: flex;
      flex-direction: column;
    }

    .stat-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 20px;
      font-weight: 800;
      color: var(--text-primary);
      margin-top: 2px;
    }

    /* ── RESPONSIVE OVERRIDES ── */
    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0;
        padding-top: 60px !important;
      }

      .topbar {
        display: none !important;
      }

      .page-header { 
        background: #fff; margin: -24px -24px 28px -24px; padding: 20px 28px; 
        border-bottom: 1px solid var(--card-border);
        display: flex; align-items: center; justify-content: space-between;
      }
    }

    @media (max-width: 768px) {
      .content-body {
        padding: 16px;
      }

      .page-title {
        font-size: 20px;
      }

      .stats-grid {
        grid-template-columns: 1fr;
        gap: 12px;
      }

      .stat-card {
        padding: 16px;
        align-items: flex-start;
        flex-direction: row;
        text-align: left;
      }

      .stat-main {
        flex-direction: row !important;
        align-items: center;
        gap: 10px !important;
        width: 100%;
        justify-content: space-between;
      }

      .stat-main>div {
        flex: 1;
        min-width: 0;
      }

      .stat-main div div {
        font-size: 13px !important;
      }

      .stat-main span {
        font-size: 10px !important;
      }

      .toolbar {
        padding: 16px;
        grid-template-columns: 1fr;
        gap: 12px;
      }

      .btn-search {
        width: 100%;
        align-self: stretch;
        margin-top: 8px;
      }

      .table-container {
        border-radius: 16px;
      }

      .table-header {
        padding: 16px;
        flex-direction: column;
        gap: 10px;
        align-items: flex-start;
      }

      .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      table {
        min-width: 1000px;
      }

      .pagination-wrap {
        flex-direction: column;
        gap: 16px;
        padding: 16px;
        align-items: center;
      }

      /* Sidebar Filter UI */
      .mobile-filter-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--accent-light);
        color: var(--accent);
        border: 1px solid rgba(108, 99, 255, 0.2);
        border-radius: 10px;
        padding: 8px 16px;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
      }

      .filter-sidebar {
        position: fixed;
        top: 0;
        right: -320px;
        width: 300px;
        height: 100%;
        background: #fff;
        z-index: 10000;
        transition: all 0.3s ease;
        box-shadow: -10px 0 30px rgba(0, 0, 0, 0.1);
        display: flex;
        flex-direction: column;
      }

      .filter-sidebar.active {
        right: 0;
      }

      .sidebar-header {
        padding: 24px;
        border-bottom: 1px solid var(--card-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .sidebar-header h3 {
        font-size: 18px;
        font-weight: 800;
      }

      .close-sidebar {
        background: none;
        border: none;
        font-size: 24px;
        color: var(--text-muted);
        cursor: pointer;
      }

      .sidebar-body {
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        overflow-y: auto;
      }

      .filter-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 9999;
        display: none;
        backdrop-filter: blur(4px);
      }

      .filter-overlay.active {
        display: block;
      }
    }

    /* Desktop toolbar fallback */
    @media (min-width: 769px) {
      .mobile-filter-btn { display: none; }
      .filter-sidebar { position: static !important; width: 100% !important; height: auto !important; box-shadow: none !important; display: block !important; margin-bottom: 24px; }
      .sidebar-header { display: none !important; }
      .sidebar-body { 
        padding: 24px !important; display: flex !important; flex-direction: row !important; flex-wrap: wrap !important; align-items: flex-end !important; 
        background: var(--card-bg) !important; border: 1px solid var(--card-border) !important; border-radius: 20px !important;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04) !important; gap: 20px !important; width: 100% !important;
      }
      .filter-group { flex: 1; min-width: 180px; margin-bottom: 0 !important; }
      .btn-search { width: auto !important; min-width: 140px; height: 44px; margin-top: 0 !important; }
      .filter-overlay { display: none !important; }
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <%- include('nav') %>
      <main class="main-content">
        <header class="topbar">
          <div class="topbar-title">Reports &rsaquo; Team Earnings</div>
        </header>

        <div class="content-body">
          <div class="page-header">
            <div style="display: flex; flex-direction: column; gap: 4px;">
              <div class="page-breadcrumb">Reports &rsaquo; <span>Team Earnings</span></div>
              <h2 class="page-title">Commission Distribution Audit</h2>
            </div>
            <button class="mobile-filter-btn" onclick="toggleFilterSidebar()">
              <i class="fas fa-filter"></i> Filter
            </button>
          </div>
          <div class="stats-grid" id="statsSummary">
            <!-- Summary card will be injected here -->
          </div>

          <!-- Filter Sidebar -->
          <div class="filter-sidebar" id="filterSidebar">
            <div class="sidebar-header">
              <h3>Filter Commissions</h3>
              <button class="close-sidebar" onclick="toggleFilterSidebar()">&times;</button>
            </div>
            <div class="sidebar-body">
              <div class="filter-group">
                <label class="filter-label">Agent Phone</label>
                <input type="text" id="phoneFilter" class="filter-input" placeholder="e.g. 91782...">
              </div>
              <div class="filter-group">
                <label class="filter-label">Start Date</label>
                <input type="date" id="startDate" class="filter-input">
              </div>
              <div class="filter-group">
                <label class="filter-label">End Date</label>
                <input type="date" id="endDate" class="filter-input">
              </div>
              <button class="btn-search" onclick="loadData(0); toggleFilterSidebar();">
                <i class="fas fa-search"></i> Apply Filters
              </button>
            </div>
          </div>
          <div class="filter-overlay" id="filterOverlay" onclick="toggleFilterSidebar()"></div>

          <div class="table-container">
            <div class="table-header">
              <h3>Commission Distribution Log</h3>
              <div id="totalRecords" style="font-size: 13px; font-weight: 600; color: var(--blue);">0 records found
              </div>
            </div>
            <div class="table-responsive">
              <table id="commissionsTable">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Agent Phone</th>
                    <th>From Subordinate</th>
                    <th>Level</th>
                    <th>Commission Amount</th>
                    <th>Date</th>
                    <th>Time</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td colspan="7" style="text-align:center; padding: 40px;">Initializing reports...</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <div class="pagination-wrap">
              <div class="pagination-info" id="paginationInfo">Showing page 1</div>
              <div class="pagination-btns" id="paginationBtns"></div>
            </div>
          </div>
        </div>
      </main>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>
  <script>
    function toggleFilterSidebar() {
      $('#filterSidebar').toggleClass('active');
      $('#filterOverlay').toggleClass('active');
    }

    let currentPage = 0;
    const limit = 20;

    function loadData(page = 0) {
      currentPage = page;
      const phone = $('#phoneFilter').val();
      const sDate = $('#startDate').val();
      const eDate = $('#endDate').val();

      let startDateMs = sDate ? new Date(sDate).setHours(0, 0, 0, 0) : null;
      let endDateMs = eDate ? new Date(eDate).setHours(23, 59, 59, 999) : null;

      $.ajax({
        type: "POST",
        url: "/api/webapi/admin/commissionReports",
        data: {
          pageno: page,
          limit: limit,
          phone: phone,
          startDate: startDateMs,
          endDate: endDateMs
        },
        dataType: "json",
        success: function (response) {
          if (response.status) {
            renderTable(response.datas);
            renderPagination(response.page_total);
            renderSummary(response.total_sum, response.today_sum, response.yesterday_sum, response.lifetime_sum);
            $('#totalRecords').text(`${response.total_count.toLocaleString()} records found`);
            $('#paginationInfo').text(`Showing page ${currentPage + 1} of ${response.page_total}`);
          }
        }
      });
    }

    function renderSummary(selected, today, yesterday, lifetime) {
      let html = `
        <div class="stat-card" style="border-color: var(--blue); background: linear-gradient(135deg, #fff 0%, #f9faff 100%)">
          <div class="stat-icon" style="background: var(--blue); color: #fff">
            <i class="fas fa-hand-holding-usd"></i>
          </div>
          <div class="stat-info" style="width: 100%;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span class="stat-label">Commission Distribution</span>
              <span style="font-size: 11px; background: rgba(45, 108, 223, 0.1); color: var(--blue); padding: 2px 8px; border-radius: 4px; font-weight: 700;">Selected Period: ₹${Number(selected).toLocaleString()}</span>
            </div>
            <div class="stat-main" style="display: flex; gap: 40px; margin-top: 12px;">
                <div>
                  <span class="stat-value" style="font-size: 14px; color: var(--text-muted); text-transform: uppercase;">Today</span>
                  <div style="font-size: 16px; font-weight: 800; color: var(--blue);">₹${Number(today).toLocaleString()}</div>
                </div>
                <div>
                  <span class="stat-value" style="font-size: 14px; color: var(--text-muted); text-transform: uppercase;">Yesterday</span>
                  <div style="font-size: 16px; font-weight: 800; color: var(--orange);">₹${Number(yesterday).toLocaleString()}</div>
                </div>
                <div>
                  <span class="stat-value" style="font-size: 14px; color: var(--text-muted); text-transform: uppercase;">Lifetime</span>
                  <div style="font-size: 16px; font-weight: 800; color: var(--text-primary);">₹${Number(lifetime).toLocaleString()}</div>
                </div>
            </div>
          </div>
        </div>
      `;
      $('#statsSummary').html(html);
    }

    function renderTable(data) {
      let html = '';
      if (data.length === 0) {
        html = '<tr><td colspan="7" style="text-align:center; padding: 40px;">No commissions found for this period.</td></tr>';
      } else {
        data.forEach(item => {
          const date = new Date(Number(item.time));
          html += `
            <tr>
              <td style="font-family: monospace; color: var(--text-muted)">#${item.id}</td>
              <td style="font-weight: 700; color: var(--accent)">91${item.phone}</td>
              <td style="font-weight: 600; color: var(--text-secondary)">ID: ${item.id_sub || item.from_user_phone}</td>
              <td><span class="level-badge">LVL ${item.level}</span></td>
              <td class="commission-val">₹${Number(item.money).toLocaleString()}</td>
              <td style="font-weight: 600">${date.toLocaleDateString()}</td>
              <td style="font-size: 12px; color: var(--text-muted)">${date.toLocaleTimeString()}</td>
            </tr>
          `;
        });
      }
      $('#commissionsTable tbody').html(html);
    }

    function renderPagination(totalPages) {
      let html = '';
      const start = Math.max(0, currentPage - 2);
      const end = Math.min(totalPages, start + 5);

      for (let i = start; i < end; i++) {
        html += `<div class="page-btn ${i === currentPage ? 'active' : ''}" onclick="loadData(${i})">${i + 1}</div>`;
      }
      $('#paginationBtns').html(html);
    }

    $(document).ready(() => {
      loadData(0);
    });
  </script>
</body>

</html>