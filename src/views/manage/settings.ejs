<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Global Settings | <%= locals.SITE_NAME || 'Starworldz' %> Admin</title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #f4f7fe;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e9edf7;
      --accent: #4361ee;
      --accent-light: rgba(67, 97, 238, 0.08);
      --text-primary: #2b3674;
      --text-secondary: #707eae;
      --text-muted: #a3aed0;
      --green: #05cd99;
      --red: #ee5d50;
      --blue: #3498db;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    .wrapper {
      display: flex;
      min-height: 100vh;
      width: 100%;
      overflow-x: hidden;
    }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
      min-width: 0;
      width: calc(100% - var(--sidebar-width));
    }

    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0 !important;
        width: 100% !important;
        max-width: 100vw !important;
        padding-top: 60px !important;
      }

      .topbar {
        display: none !important;
      }

      .page-header {
        padding: 15px 16px !important;
        margin: 0 !important;
        background: #fff;
        border-bottom: 1px solid var(--card-border);
      }
    }

    .topbar {
      background: var(--sidebar-bg);
      border-bottom: 1px solid var(--card-border);
      padding: 0 24px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .topbar-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-primary);
    }

    .content-body {
      padding: 20px;
      width: 100%;
    }

    /* ── TABS ── */
    .tabs-nav {
      display: flex;
      gap: 8px;
      margin-bottom: 20px;
      border-bottom: 2px solid var(--card-border);
      padding-bottom: 10px;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      width: 100%;
    }

    .tabs-nav::-webkit-scrollbar {
      display: none;
    }

    .tab-btn {
      background: transparent;
      border: none;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
      cursor: pointer !important;
      padding: 8px 16px;
      border-radius: 8px;
      transition: all 0.2s ease;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 6px;
      position: relative;
      z-index: 100;
    }

    .tab-btn:hover {
      background: var(--accent-light);
      color: var(--accent);
    }

    .tab-btn.active {
      background: var(--accent);
      color: #fff;
      box-shadow: 0 4px 12px rgba(67, 97, 238, 0.2);
    }

    .tab-pane {
      display: none;
    }

    .tab-pane.active {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 360px), 1fr));
      gap: 20px;
      align-items: start; /* Fix: Prevent cards from stretching to match tallest item */
    }

    /* Support for Flex-based flow builder */
    .tab-pane.active#tab-withdrawal-flow {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    @media (max-width: 768px) {
      .content-body {
        padding: 15px;
      }

      .tab-pane {
        grid-template-columns: 1fr;
        gap: 15px;
      }

      .config-card {
        padding: 16px;
        border-radius: 16px;
      }
    }

    .tab-pane.active {
      display: grid;
      animation: fadeIn 0.3s ease-out;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(5px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ── CONFIG CARD ── */
    .config-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 20px;
      padding: 20px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .card-head {
      border-bottom: 1px solid #f0f2f8;
      padding-bottom: 12px;
    }

    .card-head h3 {
      font-size: 15px;
      font-weight: 700;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .card-head h3 i {
      color: var(--accent);
      font-size: 14px;
    }

    .card-head p {
      font-size: 12px;
      color: var(--text-secondary);
      margin-top: 2px;
    }

    .field-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .field-group label {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }

    .form-control {
      height: 42px;
      border-radius: 10px;
      border: 1.5px solid var(--card-border);
      padding: 0 14px;
      font-size: 13px;
      font-weight: 500;
      outline: none;
      transition: all 0.2s;
      background: #fdfdfe;
      color: var(--text-primary);
    }

    .form-control:focus {
      border-color: var(--accent);
      background: #fff;
      box-shadow: 0 0 0 3px var(--accent-light);
    }

    .btn-save {
      height: 42px;
      border-radius: 10px;
      border: none;
      background: var(--accent);
      color: #fff !important;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 5px;
    }

    .btn-save:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 15px rgba(67, 97, 238, 0.3);
    }

    /* ── TOGGLE SWITCH ── */
    .switch-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      background: #fbfcfe;
      border-radius: 12px;
      border: 1.5px solid var(--card-border);
    }

    .switch-wrap span {
      font-weight: 600;
      font-size: 13px;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .switch {
      position: relative;
      display: inline-block;
      width: 44px;
      height: 24px;
    }

    .switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #cbd5e0;
      transition: .4s;
      border-radius: 34px;
    }

    .slider:before {
      position: absolute;
      content: "";
      height: 18px;
      width: 18px;
      left: 3px;
      bottom: 3px;
      background-color: white;
      transition: .4s;
      border-radius: 50%;
    }

    input:checked+.slider {
      background-color: var(--accent);
    }

    input:checked+.slider:before {
      transform: translateX(20px);
    }

    .preview-box {
      margin-top: 10px;
      border-radius: 12px;
      border: 1.5px dashed var(--card-border);
      padding: 8px;
      background: #fbfcfe;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100px;
    }

    .preview-box img {
      max-width: 100%;
      max-height: 120px;
      border-radius: 8px;
    }

    .file-input-wrap {
      position: relative;
      overflow: hidden;
    }

    .file-input-wrap input[type=file] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
    }

    .file-label {
      height: 42px;
      border-radius: 10px;
      border: 1.5px dashed var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      color: var(--accent);
      font-weight: 700;
      font-size: 12px;
      background: var(--accent-light);
    }

    /* ── COMPACT SWAL ── */
    .compact-swal-popup {
      padding: 1rem !important;
      border-radius: 16px !important;
      font-family: 'Inter', sans-serif !important;
    }

    .compact-swal-title {
      padding: 0 !important;
      margin-bottom: 0.5rem !important;
    }

    .compact-swal-text {
      font-size: 14px !important;
      color: #555 !important;
      margin-bottom: 1rem !important;
    }

    .compact-swal-confirm,
    .compact-swal-cancel {
      padding: 8px 20px !important;
      font-size: 13px !important;
      font-weight: 600 !important;
      border-radius: 8px !important;
    }

    /* ── MODALS FIX ── */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(26, 29, 46, 0.6);
      backdrop-filter: blur(4px);
      z-index: 2000;
      overflow-x: hidden;
      overflow-y: auto;
    }

    .modal.show {
      display: block;
      opacity: 1;
    }

    .modal.fade .modal-dialog {
      transition: transform 0.3s ease-out;
      transform: translateY(-50px);
    }

    .modal.show .modal-dialog {
      transform: none;
    }

    .modal-dialog {
      margin: 1.75rem auto;
      max-width: 500px;
      pointer-events: none;
      display: flex;
      align-items: center;
      min-height: calc(100% - 3.5rem);
    }

    .modal-content {
      position: relative;
      display: flex;
      flex-direction: column;
      width: 100%;
      pointer-events: auto;
      background-color: #fff;
      background-clip: padding-box;
      border: 1px solid rgba(0, 0, 0, .2);
      border-radius: 20px;
      outline: 0;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    }

    .modal-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--card-border);
      border-top-left-radius: 20px;
      border-top-right-radius: 20px;
    }

    .modal-title {
      margin-bottom: 0;
      line-height: 1.5;
    }

    .modal-body {
      position: relative;
      flex: 1 1 auto;
      padding: 1.5rem;
    }

    .close {
      padding: 1rem 1.5rem;
      margin: -1rem -1.5rem -1rem auto;
      background: transparent;
      border: 0;
      font-size: 1.5rem;
      font-weight: 700;
      line-height: 1;
      color: #000;
      text-shadow: 0 1px 0 #fff;
      opacity: .5;
      cursor: pointer;
    }

    .close:hover {
      opacity: .75;
    }
    /* ── WITHDRAWAL FLOW BUILDER ── */
    #flow-canvas {
      width: 100%;
      height: 600px;
      background-color: #f8f9fa;
      background-image: radial-gradient(#d1d5db 1px, transparent 1px);
      background-size: 20px 20px;
      position: relative;
      overflow: hidden;
      border: 1.5px solid var(--card-border);
      border-radius: 12px;
      cursor: crosshair;
    }

    .flow-node {
      position: absolute;
      min-width: 180px;
      background: white;
      border-radius: 10px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
      cursor: grab;
      z-index: 10;
      border: 2px solid transparent;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .flow-node:active { cursor: grabbing; }
    .flow-node:hover { border-color: var(--accent); box-shadow: 0 6px 20px rgba(0,0,0,0.12); }

    .node-header {
      padding: 8px 12px;
      border-radius: 8px 8px 0 0;
      font-weight: 700;
      color: white;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .node-trigger .node-header { background: var(--accent); }
    .node-condition .node-header { background: #f59e0b; }
    .node-action .node-header { background: #10b981; }

    .node-body {
      padding: 12px;
      font-size: 12px;
    }

    .flow-port {
      width: 10px;
      height: 10px;
      background: #4b5563;
      border-radius: 50%;
      position: absolute;
      border: 2px solid white;
    }

    .port-in { left: -5px; top: 50%; transform: translateY(-50%); }
    .port-out { right: -5px; top: 50%; transform: translateY(-50%); }
    .port-true { right: -5px; top: 30%; background: #10b981; }
    .port-false { right: -5px; top: 70%; background: #ef4444; }

    svg#flow-connections {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 5;
    }

    .flow-line {
      fill: none;
      stroke: #9ca3af;
      stroke-width: 2.5;
    }

    .var-badge {
      font-size: 10px;
      padding: 2px 6px;
      background: #f3f4f6;
      border: 1px solid #e5e7eb;
      border-radius: 4px;
      color: #374151;
      margin-right: 4px;
      margin-bottom: 4px;
      display: inline-block;
    }
  </style>
</head>

<body>

  <div class="wrapper">
    <%- include('nav') %>

      <div class="main-content">
        <header class="topbar">
          <div class="topbar-title">Control Panel &rsaquo; Global Settings</div>
        </header>

        <div class="content-body">
          <div class="tabs-nav">
            <button class="tab-btn active" data-target="tab-general"><i class="fas fa-cog"></i> General</button>
            <button class="tab-btn" data-target="tab-social"><i class="fas fa-share-alt"></i> Social & App</button>
            <button class="tab-btn" data-target="tab-payment"><i class="fas fa-wallet"></i> Payments</button>
            <button class="tab-btn" data-target="tab-incentives"><i class="fas fa-gift"></i> Incentives</button>
            <button class="tab-btn" data-target="tab-banners"><i class="fas fa-image"></i> Banners Setup</button>
            <button class="tab-btn" data-target="tab-sms"><i class="fas fa-sms"></i> SMS Settings</button>
            <button class="tab-btn" data-target="tab-api"><i class="fas fa-code"></i> API Setting</button>
            <button class="tab-btn" data-target="tab-withdrawal-methods"><i class="fas fa-money-check-alt"></i>
              Withdrawal Methods</button>

          </div>


          <!-- TAB: GENERAL -->
          <div class="tab-pane active" id="tab-general">
            <!-- SITE BRANDING FIRST -->
            <div class="config-card">
              <div class="card-head" style="border-bottom: 1px solid #f1f5f9; padding-bottom: 16px; margin-bottom: 16px;">
                <h3 style="font-size: 16px; font-weight: 800; color: #1e293b; display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-palette text-primary" style="background: var(--accent-light); padding: 8px; border-radius: 8px;"></i> Site Branding
                </h3>
                <p style="font-size: 12px; color: #64748b; margin-top: 4px;">Customize your site name and logo.</p>
              </div>

              <div
                style="display:flex;align-items:center;gap:12px;padding:12px;background:var(--accent-light);border-radius:12px;border:1px solid var(--card-border);">
                <div id="logo-preview-wrap">
                  <% if (locals.SITE_LOGO) { %>
                    <img id="logo-live-preview" src="<%= locals.SITE_LOGO %>"
                      style="width:36px;height:36px;border-radius:8px;object-fit:cover;">
                    <% } %>
                </div>
                <div>
                  <div id="sitename-live-preview" style="font-size:14px;font-weight:700;color:var(--accent);">
                    <%= locals.SITE_NAME || 'Starworldz' %>
                  </div>
                  <div style="font-size:10px;color:var(--text-secondary);">Live Branding Preview</div>
                </div>
              </div>

              <div class="field-group">
                <label>Site Name</label>
                <input type="text" class="form-control" id="site_name_input"
                  value="<%= locals.SITE_NAME || 'Starworldz' %>">
              </div>
              <div class="field-group">
                <label>Website Link</label>
                <input type="text" class="form-control" id="website_link" placeholder="Website Link">
              </div>
              <div class="field-group">
                <label>Site Logo</label>
                <div class="file-input-wrap">
                  <input type="file" id="site_logo_input" accept="image/*">
                  <div class="file-label"><i class="fas fa-image"></i> Change Logo</div>
                </div>
                <div class="preview-box" id="site_logo_show">
                  <% if (locals.SITE_LOGO) { %><img src="<%= locals.SITE_LOGO %>"
                      style="max-width: 100%; max-height: 120px; border-radius: 8px;">
                    <% } %>
                </div>
              </div>
              <button class="btn btn-primary w-100" id="save-branding" style="height: 42px; border-radius: 8px; font-weight: 700; background: var(--accent); border: none; color: #fff !important; box-shadow: 0 4px 12px rgba(67, 97, 238, 0.2); transition: all 0.2s;">
                <i class="fas fa-check mr-2"></i> Apply Branding
              </button>
            </div>

            <!-- SYSTEM MANAGEMENT (Status + IP) -->
            <div class="config-card">
              <!-- System Status Section -->
              <div class="card-head" style="border-bottom: 1px solid #f1f5f9; padding-bottom: 16px; margin-bottom: 16px;">
                <h3 style="font-size: 16px; font-weight: 800; color: #1e293b; display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-tools text-primary" style="background: var(--accent-light); padding: 8px; border-radius: 8px;"></i> System Status
                </h3>
                <p style="font-size: 12px; color: #64748b; margin-top: 4px;">Control global site accessibility.</p>
              </div>

              <div class="switch-wrap">
                <span><i class="fas fa-exclamation-triangle" style="color: var(--red);"></i> Maintenance Mode</span>
                <label class="switch">
                  <input type="checkbox" id="maintenance_toggle">
                  <span class="slider"></span>
                </label>
              </div>
              
              <div class="field-group mt-3 w-100" id="maintenance_time_group" style="display: none;">
                <label>Estimated Completion Time (Optional)</label>
                <div style="display: grid; grid-template-columns: 1fr auto; gap: 10px; width: 100%;">
                  <input type="datetime-local" id="maintenance_end_time" class="form-control" style="height: 42px; border-radius: 8px; border: 1px solid #e2e8f0; width: 100%;">
                  <button class="btn btn-danger" id="reset_maintenance_timer" style="white-space: nowrap; height: 42px; border-radius: 8px; padding: 0 15px; font-weight: 700; display: flex; align-items: center; gap: 6px; font-size: 13px; border: none; box-shadow: 0 4px 12px rgba(238, 93, 80, 0.2);">
                      <i class="fas fa-undo-alt"></i> Reset
                  </button>
                </div>
                <div class="mt-3">
                  <div class="custom-control custom-switch">
                      <input type="checkbox" class="custom-control-input" id="maintenance_auto_off">
                      <label class="custom-control-label" for="maintenance_auto_off" style="font-size: 13px; font-weight: 600; color: #475569; cursor: pointer;">Auto-Live when time ends</label>
                  </div>
                </div>
              </div>

              <!-- Divider -->
              <div style="height: 1px; background: #f1f5f9; margin: 24px 0;"></div>

              <!-- IP Control Section -->
              <div class="card-head" style="border-bottom: 1px solid #f1f5f9; padding-bottom: 16px; margin-bottom: 16px;">
                <h3 style="font-size: 16px; font-weight: 800; color: #1e293b; display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-network-wired text-primary" style="background: var(--accent-light); padding: 8px; border-radius: 8px;"></i> IP Registration Control
                </h3>
                <p style="font-size: 12px; color: #64748b; margin-top: 4px;">Manage multi-account registration limits.</p>
              </div>

              <div class="field-group mb-4">
                <label style="font-size: 11px; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; display: block;">Allow Same IP Registration</label>
                <div class="custom-control custom-switch p-0">
                    <div class="custom-control custom-switch">
                        <input type="checkbox" class="custom-control-input" id="ip_reg_status">
                        <label class="custom-control-label" for="ip_reg_status" style="font-size: 13px; font-weight: 600; color: #475569; cursor: pointer;">Enable multi-registration from same IP</label>
                    </div>
                </div>
              </div>

              <div class="field-group mb-4">
                <label style="font-size: 11px; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; display: block;">Registration Limit Per IP</label>
                <input type="number" id="ip_reg_limit" class="form-control" value="5" style="height: 42px; border-radius: 10px; border: 1.5px solid var(--card-border); font-weight: 600;">
                <p style="font-size: 11px; color: var(--text-secondary); margin-top: 6px;">Max accounts allowed per unique IP address.</p>
              </div>

              <button class="btn btn-primary w-100" id="save-ip-settings" style="height: 42px; border-radius: 10px; font-weight: 700; background: var(--accent); border: none; color: #fff !important; box-shadow: 0 4px 15px rgba(67, 97, 238, 0.3); transition: all 0.2s;">
                <i class="fas fa-save mr-2"></i> Save IP Settings
              </button>
            </div>

            <!-- CURRENCY CONFIGURATION -->
            <div class="config-card">
              <div class="card-head">
                <h3><i class="fas fa-coins"></i> Platform Currency</h3>
                <p>Define the primary currency for your site.</p>
              </div>
              <div class="field-group">
                <label>Currency Name (e.g. INR, BDT, USDT)</label>
                <input type="text" class="form-control" id="currency_name_input" placeholder="INR">
              </div>
              <div class="field-group">
                <label>Currency Symbol (e.g. ₹, ৳, $)</label>
                <input type="text" class="form-control" id="currency_symbol_input" placeholder="₹">
              </div>
