  <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.6.7/axios.min.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>

  <script>
    function loadWithdrawalConditions() {
      $.get('/api/webapi/admin/withdrawal-conditions/list', function (res) {
        if (res.status) {
          let html = '';
          res.data.forEach((item, index) => {
            const typeLabel = item.type.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
            let logicDesc = '';
            let icon = 'fa-check-circle';

            if (item.type === 'total_deposit') {
              logicDesc = `User must deposit at least <strong>₹${item.value}</strong> in total.`;
              icon = 'fa-wallet';
            } else if (item.type === 'total_bet') {
              logicDesc = `User must bet <strong>${item.value}x</strong> of their total deposits.`;
              icon = 'fa-dice';
            } else if (item.type === 'deposit_count') {
              logicDesc = `User must have at least <strong>${item.value}</strong> successful recharges.`;
              icon = 'fa-history';
            } else if (item.type === 'bet_count') {
              logicDesc = `User must have placed at least <strong>${item.value}</strong> bets.`;
              icon = 'fa-gamepad';
            }

            html += `
              <div class="flow-step" style="display: flex; align-items: center; gap: 20px; position: relative; padding: 15px; background: white; border: 1px solid var(--card-border); border-radius: 16px; transition: 0.3s; ${!item.status ? 'opacity: 0.6; filter: grayscale(1);' : ''}">
                <div class="step-number" style="width: 32px; height: 32px; background: ${item.status ? 'var(--accent)' : 'var(--text-muted)'}; color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 14px; flex-shrink: 0;">
                  ${item.order_index || (index + 1)}
                </div>
                
                <div class="step-icon" style="width: 45px; height: 45px; background: var(--accent-light); color: var(--accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;">
                  <i class="fas ${icon}"></i>
                </div>

                <div class="step-content" style="flex: 1;">
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <span style="font-weight: 700; color: var(--text-primary); font-size: 14px;">${typeLabel}</span>
                    ${item.status ? '<span style="font-size: 9px; background: #e8f5e9; color: #2e7d32; padding: 2px 8px; border-radius: 10px; font-weight: 700;">ACTIVE</span>' : '<span style="font-size: 9px; background: #eee; color: #999; padding: 2px 8px; border-radius: 10px; font-weight: 700;">DISABLED</span>'}
                  </div>
                  <div style="font-size: 12px; color: var(--text-secondary); margin-top: 3px;">${logicDesc}</div>
                </div>

                <div class="step-actions" style="display: flex; gap: 8px;">
                  <button class="btn-edit-condition" data-json='${JSON.stringify(item)}' style="width: 36px; height: 36px; border-radius: 10px; background: var(--accent-light); border: none; color: var(--accent); cursor: pointer; transition: 0.2s;">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button class="btn-delete-condition" data-id="${item.id}" style="width: 36px; height: 36px; border-radius: 10px; background: #fee; border: none; color: var(--red); cursor: pointer; transition: 0.2s;">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>

                ${index < res.data.length - 1 ? '<div style="position: absolute; bottom: -15px; left: 31px; width: 2px; height: 15px; background: var(--card-border);"></div>' : ''}
              </div>
            `;
          });
          // Append the final "Withdrawal Unlocked" step
          html += `
            <div class="flow-step" style="display: flex; align-items: center; gap: 20px; position: relative; padding: 15px; background: #e8f5e9; border: 2px solid #2e7d32; border-radius: 16px; margin-top: 10px;">
                <div class="step-number" style="width: 32px; height: 32px; background: #2e7d32; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 14px; flex-shrink: 0;">
                  <i class="fas fa-check"></i>
                </div>
                
                <div class="step-icon" style="width: 45px; height: 45px; background: rgba(46, 125, 50, 0.1); color: #2e7d32; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0;">
                  <i class="fas fa-money-bill-wave"></i>
                </div>

                <div class="step-content" style="flex: 1;">
                  <div style="font-weight: 800; color: #1b5e20; font-size: 15px;">Withdrawal Unlocked</div>
                  <div style="font-size: 12px; color: #2e7d32; margin-top: 2px;">If all previous triggers are met, the user is allowed to request a withdrawal.</div>
                </div>
                
                <div style="padding: 0 10px; font-size: 10px; font-weight: 800; color: #2e7d32; text-transform: uppercase; letter-spacing: 1px;">
                   Final Step
                </div>
            </div>
          `;

          $('#withdrawal-conditions-flow').html(html || '<div style="text-align:center; padding: 40px; color: var(--text-muted); border: 2px dashed #eee; border-radius: 20px;">No rules defined yet. Start by adding your first step!</div>');
        }
      });
    }

    function loadBanners() {
      $.ajax({
        type: "GET",
        url: "/api/webapi/admin/banners/list",
        success: function (res) {
          if (res.status) {
            let html = '';
            res.data.forEach(banner => {
              const typeLabels = {
                'home_slider': '<span class="badge" style="background:#e3f2fd;color:#1976d2">Home Slider</span>',
                'activity': '<span class="badge" style="background:#f3e5f5;color:#7b1fa2">Activity</span>',
                'guide': '<span class="badge" style="background:#fff3e0;color:#ef6c00">Guide</span>',
                'deposit_popup': '<span class="badge" style="background:#e8f5e9;color:#2e7d32">Deposit Popup</span>'
              };
              html += `
                <tr style="border-bottom: 1px solid var(--card-border);">
                  <td style="padding: 10px 8px;"><img src="${banner.image}" style="width:80px;height:40px;object-fit:cover;border-radius:6px;"></td>
                  <td style="padding: 10px 8px;">${typeLabels[banner.type] || banner.type}</td>
                  <td style="padding: 10px 8px; font-weight: 700; color: var(--accent);">${banner.priority || 0}</td>
                  <td style="padding: 10px 8px; color:var(--text-muted); font-size:11px;">${banner.link || '-'}</td>
                  <td style="padding: 10px 8px;">
                    <label class="switch" style="width:36px;height:20px;">
                      <input type="checkbox" class="toggle-banner-status" data-id="${banner.id}" data-type="${banner.type}" ${banner.status == 1 ? 'checked' : ''}>
                      <span class="slider" style="border-radius:20px;"></span>
                    </label>
                  </td>
                  <td style="padding: 10px 8px; text-align:right; white-space: nowrap;">
                    <button class="edit-banner" 
                      data-id="${banner.id}" 
                      data-type="${banner.type}" 
                      data-link="${banner.link || ''}" 
                      data-priority="${banner.priority || 0}"
                      data-content="${(banner.content || '').replace(/"/g, '&quot;')}"
                      data-image="${banner.image}"
                      style="border:none;background:transparent;color:var(--accent);cursor:pointer;font-size:14px;margin-right:15px;"><i class="fas fa-edit"></i></button>
                    <button class="delete-banner" data-id="${banner.id}" style="border:none;background:transparent;color:var(--red);cursor:pointer;font-size:14px;"><i class="fas fa-trash"></i></button>
                  </td>
                </tr>
              `;
            });
            $('#banner-list').html(html || '<tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-muted);">No banners found</td></tr>');
          }
        }
      });
    }

    $(document).ready(function () {
      $.ajax({
        type: "POST",
        url: "/admin/manager/settings/get",
        dataType: "json",
        success: function (res) {
          const momo = res.momo;
          $('#edit-momo-name_bank').val(momo.bank_name);
          $('#edit-momo-name').val(momo.username);
          $('#edit-momo-info').val(momo.upi_id);
          if (res.datas[0]?.upi_id_qr) $('#upi_id_qr_show').html(`<img src="${res.datas[0].upi_id_qr}">`);
          $('#telegram').val(res.settings[0].telegram);
          $('#cskh').val(res.settings[0].cskh);
          $('#myapp_web').val(res.settings[0].app);
          $('#whatsapp').val(res.whatsapp || '');
          $('#apk_name').val(res.apk_name || '');
          if (res.whatsapp_status == 1) $('#whatsapp_status').prop('checked', true);
          if (res.telegram_status == 1) $('#telegram_status').prop('checked', true);
          if (res.currency_name) $('#currency_name_input').val(res.currency_name);
          if (res.currency_symbol) $('#currency_symbol_input').val(res.currency_symbol);
          if (res.app_download_status == 1) $('#app_download_status').prop('checked', true);
          if (res.usdt_exchange_rate) $('#global_usdt_deposit_rate').val(res.usdt_exchange_rate);
          if (res.usdt_withdraw_rate) $('#global_usdt_withdraw_rate').val(res.usdt_withdraw_rate);
          if (res.currency_name) $('.currency-label-span').text(res.currency_name);
          if (res.cskh_status == 1) $('#cskh_status').prop('checked', true);
          if (res.apk_link) $('#apk_file_status').text("Current APK: " + res.apk_link);
          $('#signup_bonus').val(res.signup_bonus);
          $('#referral_bonus').val(res.referral_bonus);
          if (res.maintenance) {
            $('#maintenance_toggle').prop('checked', true);
            $('#maintenance_time_group').show();
          }
          if (res.maintenance_end_time) {
            // Convert to local datetime-local format (YYYY-MM-DDTHH:mm)
            const date = new Date(res.maintenance_end_time);
            const localISO = new Date(date.getTime() - date.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
            $('#maintenance_end_time').val(localISO);
          }
          if (res.maintenance_auto_off == 1) $('#maintenance_auto_off').prop('checked', true);
          if (res.siteBranding) {
            $('#site_name_input').val(res.siteBranding.site_name);
            $('#sitename-live-preview').text(res.siteBranding.site_name);
            if (res.siteBranding.site_logo) {
              $('#logo-live-preview').attr('src', res.siteBranding.site_logo);
              $('#site_logo_show').html(`<img src="${res.siteBranding.site_logo}">`);
            }
          }
          if (res.ip_reg_limit) $('#ip_reg_limit').val(res.ip_reg_limit);
          if (res.ip_reg_status !== undefined) $('#ip_reg_status').prop('checked', res.ip_reg_status == 1);

          // Populate Payment Configs
          if (res.paymentConfigs) {
            const wow = res.paymentConfigs.find(c => c.gateway_name === 'wow_pay');
            if (wow) {
              $('#wow_mch_id').val(wow.app_id);
              $('#wow_mch_key').val(wow.app_secret);
              $('#wow_status').prop('checked', wow.status == 1);
              $('#wow_min').val(wow.min_recharge);
              $('#wow_max').val(wow.max_recharge);
              $('#wow_return_url').val(wow.return_url);
              $('#wow_quick_amounts').val(wow.quick_amounts || '100,500,1000,5000');
            }
            const rs = res.paymentConfigs.find(c => c.gateway_name === 'rs_pay');
            if (rs) {
              $('#rs_mch_id').val(rs.app_id);
              $('#rs_mch_key').val(rs.app_secret);
              $('#rs_status').prop('checked', rs.status == 1);
              $('#rs_min').val(rs.min_recharge);
              $('#rs_max').val(rs.max_recharge);
              $('#rs_return_url').val(rs.return_url);
              $('#rs_quick_amounts').val(rs.quick_amounts || '100,500,1000,5000');
              $('#rs_instructions').val(rs.instructions || '');
            }
            const cp = res.paymentConfigs.find(c => c.gateway_name === 'cloud_pay');
            if (cp) {
              $('#cp_mch_id').val(cp.app_id);
              $('#cp_mch_key').val(cp.app_secret);
              $('#cp_status').prop('checked', cp.status == 1);
              $('#cp_min').val(cp.min_recharge);
              $('#cp_max').val(cp.max_recharge);
              $('#cp_return_url').val(cp.return_url);
              $('#cp_quick_amounts').val(cp.quick_amounts || '100,500,1000,5000');
              $('#cp_instructions').val(cp.instructions || '');
            }
            const upay = res.paymentConfigs.find(c => c.gateway_name === 'upay');
            if (upay) {
              $('#upay_app_id').val(upay.app_id);
              $('#upay_app_secret').val(upay.app_secret);
              $('#upay_status').prop('checked', upay.status == 1);
              $('#upay_min').val(upay.min_recharge);
              $('#upay_max').val(upay.max_recharge);
              $('#upay_return_url').val(upay.return_url);
              $('#upay_quick_amounts').val(upay.quick_amounts || '100,500,1000,5000');
              $('#upay_instructions').val(upay.instructions || '');
            }
            const wp = res.paymentConfigs.find(c => c.gateway_name === 'watchpay');
            if (wp) {
              $('#wp_mch_id').val(wp.app_id);
              $('#wp_agent_key').val(wp.app_secret);
              $('#wp_status').prop('checked', wp.status == 1);
              $('#wp_min').val(wp.min_recharge);
              $('#wp_max').val(wp.max_recharge);
              $('#wp_return_url').val(wp.return_url);
              $('#wp_quick_amounts').val(wp.quick_amounts || '100,500,1000,5000');
              $('#wp_instructions').val(wp.instructions || '');
            }
            const upi_m = res.paymentConfigs.find(c => c.gateway_name === 'upi_manual');
            if (upi_m) {
              $('#upi_m_name').val(upi_m.app_id);
              $('#upi_m_id').val(upi_m.app_secret);
              $('#upi_m_status').prop('checked', upi_m.status == 1);
              $('#upi_m_min').val(upi_m.min_recharge);
              $('#upi_m_max').val(upi_m.max_recharge);
              $('#upi_m_quick_amounts').val(upi_m.quick_amounts || '100,500,1000,5000');
              $('#upi_m_instructions').val(upi_m.instructions || '');
              if (upi_m.qr_code) $('#upi_m_qr_show').html(`<img src="${upi_m.qr_code}" style="max-width:100px;">`);
            }
            const usdt_m = res.paymentConfigs.find(c => c.gateway_name === 'usdt_manual');
            if (usdt_m) {
              $('#usdt_m_addr').val(usdt_m.app_id);
              $('#usdt_m_status').prop('checked', usdt_m.status == 1);
              $('#usdt_m_min').val(usdt_m.min_recharge);
              $('#usdt_m_max').val(usdt_m.max_recharge);
              $('#usdt_m_quick_amounts').val(usdt_m.quick_amounts || '10,50,100,500,1000');
              $('#usdt_m_instructions').val(usdt_m.instructions || '');
              if (usdt_m.qr_code) $('#usdt_m_qr_show').html(`<img src="${usdt_m.qr_code}" style="max-width:100px;">`);
            }
            const cc = res.paymentConfigs.find(c => c.gateway_name === 'ccpayment');
            if (cc) {
              $('#cc_app_id').val(cc.app_id);
              $('#cc_app_secret').val(cc.app_secret);
              $('#cc_status').prop('checked', cc.status == 1);
              $('#cc_min').val(cc.min_recharge);
              $('#cc_max').val(cc.max_recharge);
              $('#cc_return_url').val(cc.return_url);
              $('#cc_quick_amounts').val(cc.quick_amounts || '10,50,100,500,1000,5000');
              $('#cc_instructions').val(cc.instructions || '');
            }
            const ug = res.paymentConfigs.find(c => c.gateway_name === 'upi_gateway');
            if (ug) {
              $('#ug_key').val(ug.app_secret);
              $('#ug_status').prop('checked', ug.status == 1);
              $('#ug_min').val(ug.min_recharge);
              $('#ug_max').val(ug.max_recharge);
              $('#ug_return_url').val(ug.return_url);
              $('#ug_quick_amounts').val(ug.quick_amounts || '100,500,1000,5000');
              $('#ug_instructions').val(ug.instructions || '');
            }
          }
          if (res.website_link) $('#website_link').val(res.website_link);
          if (res.wc_ag_code) $('#wc_ag_code').val(res.wc_ag_code);
          if (res.wc_ag_token) $('#wc_ag_token').val(res.wc_ag_token);
          if (res.wc_ag_secret) $('#wc_ag_secret').val(res.wc_ag_secret);
          if (res.currency_name) $('#currency_name_input').val(res.currency_name);
          if (res.currency_symbol) $('#currency_symbol_input').val(res.currency_symbol);


          // Populate Withdrawal Configs
          if (res.daily_withdraw_limit) {
            $('#daily_withdraw_limit').val(res.daily_withdraw_limit);
          }
          if (res.withdrawalConfigs) {
            const bank = res.withdrawalConfigs.find(c => c.method_name === 'BANK_CARD');
            if (bank) {
              $('#withdraw_bank_min').val(bank.min_amount);
              $('#withdraw_bank_max').val(bank.max_amount);
              $('#withdraw_bank_status').prop('checked', bank.status == 1);
            }
            const usdt = res.withdrawalConfigs.find(c => c.method_name === 'USDT_ADDRESS');
            if (usdt) {
              $('#withdraw_usdt_min').val(usdt.min_amount);
              $('#withdraw_usdt_max').val(usdt.max_amount);
              $('#withdraw_usdt_status').prop('checked', usdt.status == 1);
            }
            const upi = res.withdrawalConfigs.find(c => c.method_name === 'UPI');
            if (upi) {
              $('#withdraw_upi_min').val(upi.min_amount);
              $('#withdraw_upi_max').val(upi.max_amount);
              $('#withdraw_upi_status').prop('checked', upi.status == 1);
            }
          }
        }
      });

      loadBanners();
      loadWithdrawalConditions();

      // --- Tab Logic ---
      $(document).on('click', '.tab-btn', function () {
        $('.tab-btn').removeClass('active');
        $(this).addClass('active');
        $('.tab-pane').removeClass('active');
        const target = $(this).data('target');
        $('#' + target).addClass('active');
        if (target === 'tab-withdrawal-flow') loadWithdrawalFlow();
        else if (target === 'tab-banners') loadBanners();
      });

      // --- API Gateway Tab Logic ---
      $(document).on('click', '.gateway-tab-btn', function () {
        $('.gateway-tab-btn').removeClass('active').css('color', 'var(--text-secondary)');
        $(this).addClass('active').css('color', 'var(--accent)');
        $('.gateway-pane').hide().removeClass('active');
        const gateway = $(this).data('gateway');
        $(`#pane-${gateway}`).show().addClass('active');
      });

      $('.gateway-tab-btn.active').css('color', 'var(--accent)');

      // Save Gateway Config
      $(document).on('click', '.save-gateway', async function () {
        const gateway = $(this).data('gateway');

        if (gateway === 'upi_manual' || gateway === 'usdt_manual') {
          const fd = new FormData();
          fd.append('gateway_name', gateway);

          if (gateway === 'upi_manual') {
            fd.append('app_id', $('#upi_m_name').val());
            fd.append('app_secret', $('#upi_m_id').val());
            fd.append('status', $('#upi_m_status').is(':checked') ? 1 : 0);
            fd.append('min_recharge', $('#upi_m_min').val());
            fd.append('max_recharge', $('#upi_m_max').val());
            fd.append('quick_amounts', $('#upi_m_quick_amounts').val());
            fd.append('instructions', $('#upi_m_instructions').val());
            if ($('#upi_m_qr_input')[0].files[0]) fd.append('qr_code', $('#upi_m_qr_input')[0].files[0]);
          } else {
            fd.append('app_id', $('#usdt_m_addr').val());
            fd.append('status', $('#usdt_m_status').is(':checked') ? 1 : 0);
            fd.append('min_recharge', $('#usdt_m_min').val());
            fd.append('max_recharge', $('#usdt_m_max').val());
            fd.append('quick_amounts', $('#usdt_m_quick_amounts').val());
            fd.append('instructions', $('#usdt_m_instructions').val());
            if ($('#usdt_m_qr_input')[0].files[0]) fd.append('qr_code', $('#usdt_m_qr_input')[0].files[0]);
          }

          try {
            const res = await axios.post('/admin/manager/settings/payment-gateway', fd);
            if (res.data.status) alertMsg(res.data.message);
            else alertMsg(res.data.message, 'error');
          } catch (e) { alertMsg("Failed to save config", 'error'); }
          return;
        }

        let data = { gateway_name: gateway };
        if (gateway === 'ccpayment') {
          data = {
            gateway_name: 'ccpayment',
            app_id: $('#cc_app_id').val(),
            app_secret: $('#cc_app_secret').val(),
            min_recharge: $('#cc_min').val(),
            max_recharge: $('#cc_max').val(),
            return_url: $('#cc_return_url').val(),
            quick_amounts: $('#cc_quick_amounts').val(),
            instructions: $('#cc_instructions').val(),
            status: $('#cc_status').is(':checked') ? 1 : 0
          };
        } else if (gateway === 'wowpay') {
          data = {
            gateway_name: 'wow_pay',
            app_id: $('#wow_mch_id').val(),
            app_secret: $('#wow_mch_key').val(),
            min_recharge: $('#wow_min').val(),
            max_recharge: $('#wow_max').val(),
            return_url: $('#wow_return_url').val(),
            quick_amounts: $('#wow_quick_amounts').val(),
            instructions: $('#wow_instructions').val(),
            status: $('#wow_status').is(':checked') ? 1 : 0
          };
        } else if (gateway === 'rspay') {
          data = {
            gateway_name: 'rs_pay',
            app_id: $('#rs_mch_id').val(),
            app_secret: $('#rs_mch_key').val(),
            min_recharge: $('#rs_min').val(),
            max_recharge: $('#rs_max').val(),
            return_url: $('#rs_return_url').val(),
            quick_amounts: $('#rs_quick_amounts').val(),
            instructions: $('#rs_instructions').val(),
            status: $('#rs_status').is(':checked') ? 1 : 0
          };
        } else if (gateway === 'cloudpay') {
          data = {
            gateway_name: 'cloud_pay',
            app_id: $('#cp_mch_id').val(),
            app_secret: $('#cp_mch_key').val(),
            min_recharge: $('#cp_min').val(),
            max_recharge: $('#cp_max').val(),
            return_url: $('#cp_return_url').val(),
            quick_amounts: $('#cp_quick_amounts').val(),
            instructions: $('#cp_instructions').val(),
            status: $('#cp_status').is(':checked') ? 1 : 0
          };
        } else if (gateway === 'upigateway') {
          data = {
            gateway_name: 'upi_gateway',
            app_secret: $('#ug_key').val(),
            min_recharge: $('#ug_min').val(),
            max_recharge: $('#ug_max').val(),
            return_url: $('#ug_return_url').val(),
            quick_amounts: $('#ug_quick_amounts').val(),
            instructions: $('#ug_instructions').val(),
            status: $('#ug_status').is(':checked') ? 1 : 0
          };
        } else if (gateway === 'upay') {
          data = {
            gateway_name: 'upay',
            app_id: $('#upay_app_id').val(),
