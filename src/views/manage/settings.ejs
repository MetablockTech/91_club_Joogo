      // --- WITHDRAWAL FLOW LOGIC (Polished n8n Style) ---
      let flowData = { nodes: [], edges: [] };
      const flowCanvas = document.getElementById('flow-canvas');
      const flowSvg = document.getElementById('flow-connections');
      let flowDraggingNode = null;
      let flowDragOffset = { x: 0, y: 0 };

      function renderFlowNode(node) {
        const div = document.createElement('div');
        div.className = `flow-node node-${node.type}`;
        div.id = `flnode-${node.id}`;
        div.style.left = `${node.x}px`;
        div.style.top = `${node.y}px`;
        div.style.padding = '0'; // Custom padding for polished look
        div.style.width = '220px';

        let icon = 'fa-play-circle';
        if(node.type === 'condition') icon = 'fa-filter';
        if(node.type === 'action') icon = 'fa-bolt';

        let bodyHtml = '';
        if (node.type === 'condition') {
          bodyHtml = `
            <div style="padding: 10px; border-bottom: 1px solid #f1f5f9;">
              <div style="font-size: 10px; color: #64748b; margin-bottom: 4px; text-transform: uppercase; font-weight: 700;">Logic Formula</div>
              <input type="text" class="form-control" style="height: 30px; font-family: 'Fira Code', monospace; font-size: 11px; background: #f8fafc;" 
                     value="${node.formula || ''}" onchange="updateFlowNode('${node.id}', 'formula', this.value)" placeholder="{{deposit}} > 500">
            </div>
          `;
        } else if (node.type === 'action') {
          bodyHtml = `
            <div style="padding: 10px; border-bottom: 1px solid #f1f5f9;">
               <select class="form-control" style="height: 32px; font-size: 12px; font-weight: 600;" onchange="updateFlowNode('${node.id}', 'action', this.value)">
                <option value="allow" ${node.action === 'allow' ? 'selected' : ''}>✅ ALLOW</option>
                <option value="reject" ${node.action === 'reject' ? 'selected' : ''}>❌ REJECT</option>
                <option value="audit" ${node.action === 'audit' ? 'selected' : ''}>🔍 MANUAL AUDIT</option>
              </select>
            </div>
            ${node.action === 'reject' ? `
              <div style="padding: 10px;">
                <input type="text" class="form-control" style="height: 30px; font-size: 11px;" 
                       value="${node.message || ''}" onchange="updateFlowNode('${node.id}', 'message', this.value)" placeholder="Error message for user">
              </div>
            ` : ''}
          `;
        } else if (node.type === 'trigger') {
          bodyHtml = `<div style="padding: 15px; font-size: 12px; color: #475569; font-weight: 500;">User submits a withdrawal request.</div>`;
        }

        div.innerHTML = `
          <div style="padding: 10px 12px; background: #fff; border-radius: 10px 10px 0 0; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: 10px;">
            <div style="width: 24px; height: 24px; border-radius: 6px; display: flex; align-items: center; justify-content: center; background: ${node.type==='condition'?'#fef3c7':(node.type==='action'?'#dcfce7':'#dbeafe')}; color: ${node.type==='condition'?'#d97706':(node.type==='action'?'#059669':'#2563eb')};">
              <i class="fas ${icon}" style="font-size: 12px;"></i>
            </div>
            <span style="font-size: 12px; font-weight: 700; color: #1e293b; flex: 1;">${node.label}</span>
            <i class="fas fa-trash" style="cursor:pointer; font-size: 10px; color: #cbd5e1;" onclick="deleteFlowNode('${node.id}')"></i>
          </div>
          <div class="node-body" style="background: #fff; border-radius: 0 0 10px 10px;">${bodyHtml}</div>
          
          ${node.type !== 'trigger' ? '<div class="flow-port port-in" style="background: #94a3b8; border: 2px solid #fff; width: 12px; height: 12px;"></div>' : ''}
          
          ${node.type === 'condition' ? `
            <div class="flow-port port-out port-true" title="If True" style="top: 30%; right: -6px; width: 12px; height: 12px;"></div>
            <div class="flow-port port-out port-false" title="If False" style="top: 70%; right: -6px; width: 12px; height: 12px;"></div>
            <div style="position: absolute; right: 10px; top: 25%; font-size: 9px; font-weight: 800; color: #10b981;">TRUE</div>
            <div style="position: absolute; right: 10px; top: 65%; font-size: 9px; font-weight: 800; color: #ef4444;">FALSE</div>
          ` : (node.type !== 'action' ? '<div class="flow-port port-out" style="background: #94a3b8; border: 2px solid #fff; width: 12px; height: 12px;"></div>' : '')}
        `;

        div.onmousedown = (e) => {
          if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT' || e.target.classList.contains('fa-trash')) return;
          flowDraggingNode = node;
          const rect = div.getBoundingClientRect();
          flowDragOffset.x = e.clientX - rect.left;
          flowDragOffset.y = e.clientY - rect.top;
          div.style.zIndex = 1000;
        };

        flowCanvas.appendChild(div);
      }

      window.updateFlowNode = (id, field, value) => {
        const node = flowData.nodes.find(n => n.id === id);
        if (node) {
          node[field] = value;
          if (field === 'action') refreshFlowCanvas();
        }
      };

      window.deleteFlowNode = (id) => {
        flowData.nodes = flowData.nodes.filter(n => n.id !== id);
        flowData.edges = flowData.edges.filter(e => e.from !== id && e.to !== id);
        refreshFlowCanvas();
      };

      function drawFlowEdges() {
        flowSvg.innerHTML = '';
        flowData.edges.forEach(edge => {
          const from = flowData.nodes.find(n => n.id === edge.from);
          const to = flowData.nodes.find(n => n.id === edge.to);
          if (!from || !to) return;

          const fromEl = document.getElementById(`flnode-${from.id}`);
          const toEl = document.getElementById(`flnode-${to.id}`);
          if (!fromEl || !toEl) return;

          let startX = from.x + fromEl.offsetWidth;
          let startY = from.y + (fromEl.offsetHeight / 2);
          if (from.type === 'condition') {
            startY = from.y + (fromEl.offsetHeight * (edge.type === 'true' ? 0.3 : 0.7));
          }

          let endX = to.x;
          let endY = to.y + (toEl.offsetHeight / 2);

          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          const midX = (startX + endX) / 2;
          const d = `M ${startX} ${startY} C ${midX} ${startY}, ${midX} ${endY}, ${endX} ${endY}`;
          path.setAttribute('d', d);
          path.setAttribute('class', 'flow-line');
          path.style.stroke = edge.type === 'true' ? '#10b981' : (edge.type === 'false' ? '#ef4444' : '#94a3b8');
          flowSvg.appendChild(path);
        });
      }

      function refreshFlowCanvas() {
        flowCanvas.querySelectorAll('.flow-node').forEach(n => flowCanvas.removeChild(n));
        flowData.nodes.forEach(renderFlowNode);
        drawFlowEdges();
      }

      $(flowCanvas).mousemove((e) => {
        if (!flowDraggingNode) return;
        const rect = flowCanvas.getBoundingClientRect();
        let x = e.clientX - rect.left - flowDragOffset.x;
        let y = e.clientY - rect.top - flowDragOffset.y;
        x = Math.round(x / 10) * 10;
        y = Math.round(y / 10) * 10;
        flowDraggingNode.x = x;
        flowDraggingNode.y = y;
        const el = document.getElementById(`flnode-${flowDraggingNode.id}`);
        el.style.left = `${x}px`;
        el.style.top = `${y}px`;
        drawFlowEdges();
      });

      $(window).mouseup(() => {
        if (flowDraggingNode) {
          document.getElementById(`flnode-${flowDraggingNode.id}`).style.zIndex = 10;
          flowDraggingNode = null;
        }
      });

      async function loadWithdrawalFlow() {
        try {
          const res = await $.get('/api/webapi/admin/withdrawal-flow/get');
          if (res.status && res.data) {
            flowData = JSON.parse(res.data.flow_json);
            refreshFlowCanvas();
          }
        } catch (e) { console.error("Flow Load Error", e); }
      }

      $('#add-condition-node').click(() => {
        const id = 'c' + Date.now();
        flowData.nodes.push({ id, type: 'condition', label: 'Condition Node', x: 250, y: 150, formula: '' });
        refreshFlowCanvas();
      });

      $('#add-action-node').click(() => {
        const id = 'a' + Date.now();
        flowData.nodes.push({ id, type: 'action', label: 'Action Node', x: 550, y: 150, action: 'allow' });
        refreshFlowCanvas();
      });

      $('#save-withdrawal-flow').click(async () => {
        try {
          const res = await $.post('/api/webapi/admin/withdrawal-flow/save', { flow_json: JSON.stringify(flowData) });
          if (res.status) alertMsg('Workflow saved successfully!');
          else alertMsg(res.message, 'error');
        } catch (e) { alertMsg('Failed to save flow', 'error'); }
      });

      $('#run-simulation').click(function() {
        const testVars = {};
        $('.sim-val').each(function() {
          testVars[$(this).data('var')] = parseFloat($(this).val()) || 0;
        });

        const evalFormulaLocal = (formula, vars) => {
          try {
            let processed = formula;
            for (const [key, value] of Object.entries(vars)) {
              const regex = new RegExp(`{{${key}}}`, 'g');
              processed = processed.replace(regex, value);
            }
            if (/[^0-9\+\-\*\/\(\)\s\.\>\<\=\!\&\|]/.test(processed)) return false;
            return !!(new Function(`return ${processed}`)());
          } catch (e) { return false; }
        };

        let currentNode = flowData.nodes.find(n => n.type === 'trigger');
        let simResult = { status: 'Unknown', msg: 'No trigger found' };
        let safety = 0;

        while (currentNode && safety < 50) {
          safety++;
          if (currentNode.type === 'action') {
            simResult = { 
              status: currentNode.action.toUpperCase(), 
              msg: currentNode.action === 'reject' ? currentNode.message : 'Conditions passed!',
              color: currentNode.action === 'allow' ? '#dcfce7' : (currentNode.action === 'audit' ? '#fef9c3' : '#fee2e2'),
              textColor: currentNode.action === 'allow' ? '#166534' : (currentNode.action === 'audit' ? '#854d0e' : '#991b1b')
            };
            break;
          }

          if (currentNode.type === 'condition') {
            const val = evalFormulaLocal(currentNode.formula, testVars);
            const edge = flowData.edges.find(e => e.from === currentNode.id && e.type === (val ? 'true' : 'false'));
            if (!edge) {
                simResult = { status: 'STUCK', msg: `No path found`, color: '#eee' };
                break;
            }
            currentNode = flowData.nodes.find(n => n.id === edge.to);
          } else {
            const edge = flowData.edges.find(e => e.from === currentNode.id);
            if (!edge) break;
            currentNode = flowData.nodes.find(n => n.id === edge.to);
          }
        }

        $('#sim-result').css({ 'display': 'block', 'background': simResult.color, 'color': simResult.textColor });
        $('#sim-status').text(simResult.status);
        $('#sim-msg').text(simResult.msg).css('color', simResult.textColor);
      });

      loadWithdrawalFlow();
    });

  </script>
  <input type="file" id="edit_banner_image_input" style="display:none" accept="image/*">
</body>

</html>