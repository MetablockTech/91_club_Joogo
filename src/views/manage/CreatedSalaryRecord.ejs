<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Salary Records | <%= locals.SITE_NAME || 'Starworldz' %> Admin</title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@600&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --accent-light: rgba(108, 99, 255, 0.08);
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    .wrapper { display: flex; min-height: 100vh; }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1; display: flex; flex-direction: column; transition: all 0.3s; min-width: 0;
    }

    @media (max-width: 991.98px) { .main-content { margin-left: 0; } }

    .topbar {
      background: var(--sidebar-bg); border-bottom: 1px solid var(--card-border);
      padding: 0 28px; height: 70px; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 50;
    }
    .topbar-title { font-size: 18px; font-weight: 700; color: var(--text-primary); }

    .content-body { padding: 28px; }

    /* ── FORM CARD ── */
    .form-card {
      background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 24px;
      padding: 30px; margin-bottom: 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }
    .form-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; align-items: flex-end;
    }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-group label { font-size: 12px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
    .form-control {
      height: 48px; border-radius: 12px; border: 1.5px solid var(--card-border);
      padding: 0 16px; font-size: 14px; font-weight: 500; outline: none; transition: all 0.2s;
      background: #f9fbfd;
    }
    .form-control:focus { border-color: var(--accent); background: #fff; box-shadow: 0 0 0 4px var(--accent-light); }

    .btn-submit {
      height: 48px; background: var(--accent); color: #fff; border: none; border-radius: 12px;
      font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(108, 99, 255, 0.25); }

    /* ── TABLE CARD ── */
    .table-card {
      background: #fff; border: 1px solid var(--card-border); border-radius: 24px;
      overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }
    .table-responsive { overflow-x: auto; width: 100%; }
    table { width: 100%; border-collapse: collapse; min-width: 800px; }
    thead th {
      background: #fbfcfe; padding: 16px 20px; text-align: left;
      font-size: 11px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;
      border-bottom: 1px solid var(--card-border);
    }
    tbody tr { border-bottom: 1px solid #f8f9fb; transition: background 0.2s; }
    tbody tr:hover { background: rgba(108, 99, 255, 0.02); }
    td { padding: 16px 20px; font-size: 14px; font-weight: 500; vertical-align: middle; }

    .badge-type {
      padding: 4px 10px; border-radius: 8px; font-size: 11px; font-weight: 700;
      background: var(--accent-light); color: var(--accent); text-transform: uppercase;
    }
    .amount { font-family: 'JetBrains Mono', monospace; font-weight: 800; color: var(--green); }
    .phone { font-weight: 700; color: var(--text-primary); }

    /* ── RESPONSIVE OVERRIDES ── */
    @media (max-width: 991.98px) {
      .main-content { margin-left: 0; padding-top: 60px !important; }
      .topbar { display: none !important; }
    }

    @media (max-width: 768px) {
      .content-body { padding: 12px !important; }
      .form-card { padding: 20px; border-radius: 18px; margin-bottom: 20px; }
      .form-grid { grid-template-columns: 1fr; gap: 16px; }
      .btn-submit { width: 100%; }
      
      .table-card { border-radius: 18px; }
      .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      table { min-width: 800px; } 
      
      .pagination-wrap { flex-direction: column; gap: 12px; }
    }
    
    /* Breadcrumb styling */
    .page-header { margin-bottom: 24px; }
    .page-title { font-size: 20px; font-weight: 800; color: var(--text-primary); }
    .page-breadcrumb { font-size: 13px; color: var(--text-muted); margin-top: 4px; }
    .page-breadcrumb span { color: var(--accent); font-weight: 600; }

    /* Pagination Styling */
    .pagination-wrap {
      display: flex; align-items: center; justify-content: center; gap: 15px; padding: 25px;
      background: #fff; border-top: 1px solid var(--card-border);
    }
    .pag-btn {
      width: 40px; height: 40px; border-radius: 12px; border: 1px solid var(--card-border);
      background: #fff; display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: all 0.2s; color: var(--text-secondary);
    }
    .pag-btn:hover:not(.disabled) { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
    .pag-btn.disabled { opacity: 0.4; cursor: not-allowed; }
    .page-info { font-size: 14px; font-weight: 700; color: var(--text-primary); min-width: 100px; text-align: center; }
  </style>
</head>
<body>

  <div class="wrapper">
    <%- include('nav') %>

    <div class="main-content">
      <header class="topbar" style="position: relative;">
        <div class="topbar-title">Salary Management</div>
      </header>

      <div class="content-body">
        
        <div class="page-header">
          <div class="page-breadcrumb">Management &rsaquo; <span>Salary Management</span></div>
          <h2 class="page-title">Salary Distribution</h2>
        </div>
        
        <!-- Creation Form -->
        <div class="form-card">
          <div style="margin-bottom: 20px;">
            <h2 style="font-size: 18px; font-weight: 800; color: var(--text-primary);">Create Salary Record</h2>
            <p style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">Manually assign compensation records to promoters and collaborators.</p>
          </div>
          <form id="salaryForm" class="form-grid">
            <div class="form-group">
              <label>Target Account Phone</label>
              <input type="tel" class="form-control" id="phoneNumber" placeholder="e.g. 9876543210" required>
            </div>
            <div class="form-group">
              <label>Salary Amount (₹)</label>
              <input type="number" class="form-control" id="amount" placeholder="0.00" required>
            </div>
            <div class="form-group">
              <label>Payment Cycle</label>
              <select class="form-control" id="type" required>
                <option value="" selected disabled>Select Cycle</option>
                <option value="daily">Daily Salary</option>
                <option value="weekly">Weekly Reward</option>
                <option value="monthly">Monthly Salary</option>
              </select>
            </div>
            <button type="submit" class="btn-submit" id="submit">
              <i class="fas fa-plus-circle"></i> Create Record
            </button>
          </form>
        </div>

        <!-- Records Table -->
        <div class="table-card">
          <header style="padding: 20px 24px; border-bottom: 1px solid var(--card-border);">
            <h3 style="font-size: 15px; font-weight: 700; color: var(--text-secondary);">Recent Salary Distributions</h3>
          </header>
          <div class="table-responsive">
            <table id="tableget">
              <thead>
                <tr>
                  <th>Receiver Account</th>
                  <th class="text-center">Cycle Type</th>
                  <th class="text-center">Distributed Amount</th>
                  <th class="text-center">Distribution Time</th>
                </tr>
              </thead>
              <tbody>
                <!-- Data injected via JS -->
              </tbody>
            </table>
          </div>
          <!-- Pagination -->
          <div class="pagination-wrap">
            <div class="pag-btn" id="prev-btn"><i class="fas fa-chevron-left"></i></div>
            <div class="page-info">Page <span id="current-page">1</span></div>
            <div class="pag-btn" id="next-btn"><i class="fas fa-chevron-right"></i></div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    $(document).ready(function () {
      let currentPage = 1;
      const limit = 20;

      function formateT(params) {
        let result = params < 10 ? "0" + params : params;
        return result;
      }
      function timerJoin(params = '') {
        let date = params ? new Date(Number(params)) : new Date();
        let years = formateT(date.getFullYear());
        let months = formateT(date.getMonth() + 1);
        let days = formateT(date.getDate());
        let hours = date.getHours();
        let minutes = formateT(date.getMinutes());
        let ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12 || 12;
        return `${years}/${months}/${days} ${formateT(hours)}:${minutes} ${ampm}`;
      }

      function alertMsg(text, icon = 'success') {
        Swal.fire({ text, icon, toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
      }

      $("#salaryForm").on("submit", function (e) {
        e.preventDefault();
        const phone = $("#phoneNumber").val().trim();
        const amount = $("#amount").val().trim();
        const type = $("#type").val().trim();

        $.ajax({
          type: "POST",
          url: "/api/webapi/admin/CreatedSalary",
          dataType: "JSON",
          data: { phone, amount, type },
          success: function (response) {
            alertMsg('Salary record created successfully!');
            document.getElementById('salaryForm').reset();
            currentPage = 1;
            fetchAndUpdateTable();
          },
          error: function (error) {
            alertMsg('Unable to create salary record.', 'error');
          }
        });
      });

      function fetchAndUpdateTable() {
        $.ajax({
          type: "POST",
          url: "/api/webapi/admin/getSalary",
          dataType: "json",
          data: {
            page: currentPage,
            limit: limit
          },
          success: function (response) {
            updateTable(response);
            $("#current-page").text(currentPage);
            $("#prev-btn").toggleClass("disabled", currentPage === 1);
            $("#next-btn").toggleClass("disabled", !response.rows || response.rows.length < limit);
          }
        });
      }

      function updateTable(data) {
        var tableBody = $('#tableget').find('tbody');
        tableBody.empty();
        
        if (Array.isArray(data.rows) && data.rows.length > 0) {
          data.rows.forEach(function (item) {
            var row = `<tr>
              <td class="phone">91${item.phone}</td>
              <td class="text-center"><span class="badge-type">${item.type}</span></td>
              <td class="text-center amount">₹${Number(item.amount).toFixed(2)}</td>
              <td class="text-center" style="font-size: 13px; color: var(--text-secondary); font-weight: 600;">${timerJoin(item.time)}</td>
            </tr>`;
            tableBody.append(row);
          });
        } else {
          tableBody.append('<tr><td colspan="4" class="text-center p-4 text-muted">No distribution records found.</td></tr>');
        }
      }

      $("#prev-btn").click(function() {
        if (currentPage > 1) {
          currentPage--;
          fetchAndUpdateTable();
        }
      });

      $("#next-btn").click(function() {
        if (!$(this).hasClass("disabled")) {
          currentPage++;
          fetchAndUpdateTable();
        }
      });

      fetchAndUpdateTable();
    });
  </script>
</body>
</html>