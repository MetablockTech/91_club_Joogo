<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Collaborator Statistics | <%= locals.SITE_NAME || 'Starworldz' %> Admin</title>
  <link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #f0f2f8;
      --sidebar-bg: #ffffff;
      --card-bg: #ffffff;
      --card-border: #e3e7f0;
      --accent: #6c63ff;
      --accent-light: rgba(108, 99, 255, 0.08);
      --text-primary: #1a1d2e;
      --text-secondary: #5a5f7a;
      --text-muted: #9ea3b8;
      --green: #00b894;
      --red: #e17055;
      --yellow: #f1c40f;
      --blue: #3498db;
      --sidebar-width: 260px;
    }

    body {
      font-family: 'Inter', sans-serif !important;
      background: var(--bg);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    .wrapper {
      display: flex;
      min-height: 100vh;
    }

    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
      min-width: 0;
    }

    @media (max-width: 991.98px) {
      .main-content {
        margin-left: 0;
      }
    }

    .topbar {
      background: var(--sidebar-bg);
      border-bottom: 1px solid var(--card-border);
      padding: 0 28px;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .topbar-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-primary);
    }

    .content-body {
      padding: 28px;
    }

    /* ── PAGE HEADER ── */
    .page-header {
      margin-bottom: 24px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .page-title {
      font-size: 20px;
      font-weight: 800;
      color: var(--text-primary);
    }

    .page-breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .page-breadcrumb span {
      color: var(--accent);
      font-weight: 600;
    }

    /* ── STATS GRID ── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 28px;
    }

    .stat-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 20px;
      padding: 20px;
      display: flex;
      align-items: center;
      gap: 16px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
      transition: transform 0.2s;
    }

    .stat-card:hover {
      transform: translateY(-4px);
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }

    .icon-blue { background: rgba(52, 152, 219, 0.1); color: var(--blue); }
    .icon-green { background: rgba(0, 184, 148, 0.1); color: var(--green); }
    .icon-red { background: rgba(225, 112, 85, 0.1); color: var(--red); }
    .icon-yellow { background: rgba(241, 196, 15, 0.1); color: var(--yellow); }
    .icon-purple { background: var(--accent-light); color: var(--accent); }

    .stat-info {
      display: flex;
      flex-direction: column;
    }

    .stat-label {
      font-size: 12px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 18px;
      font-weight: 800;
      color: var(--text-primary);
      margin-top: 2px;
    }

    /* ── TOOLBAR / FILTER ── */
    .toolbar {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 16px;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 28px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    }

    .filter-label {
      font-size: 13px;
      font-weight: 700;
      color: var(--text-secondary);
    }

    .date-input {
      background: #f7f8fc;
      border: 1px solid var(--card-border);
      border-radius: 10px;
      padding: 8px 12px;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
      outline: none;
      transition: all 0.2s;
    }

    .date-input:focus {
      border-color: var(--accent);
      background: #fff;
    }

    /* ── SECTION CARDS ── */
    .section-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      margin-bottom: 28px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    }

    .section-header {
      padding: 20px 24px;
      border-bottom: 1px solid var(--card-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #fbfcfe;
    }

    .section-title {
      font-size: 15px;
      font-weight: 800;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* ── TABLES ── */
    .table-responsive {
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead th {
      padding: 14px 20px;
      text-align: center;
      font-size: 11px;
      font-weight: 800;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      border-bottom: 1px solid var(--card-border);
    }

    tbody tr {
      border-bottom: 1px solid #f8f9fb;
      transition: background 0.2s;
    }

    tbody tr:hover {
      background: rgba(108, 99, 255, 0.01);
    }

    td {
      padding: 14px 20px;
      font-size: 13px;
      font-weight: 600;
      text-align: center;
      vertical-align: middle;
    }

    .badge {
      padding: 4px 10px;
      border-radius: 8px;
      font-size: 11px;
      font-weight: 700;
    }

    .bg-success-light { background: rgba(0, 184, 148, 0.1); color: var(--green); }
    .bg-warning-light { background: rgba(241, 196, 15, 0.1); color: var(--yellow); }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .content-body { padding: 16px; }
      .stats-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
      .stat-card { padding: 14px; gap: 12px; }
      .stat-icon { width: 40px; height: 40px; font-size: 16px; }
      .stat-value { font-size: 15px; }
      .section-card { border-radius: 16px; }
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <%- include('nav') %>

    <div class="main-content">
      <header class="topbar">
        <div class="topbar-title">Partner Statistics</div>
      </header>

      <div class="content-body">
        <div class="page-header">
          <div>
            <h2 class="page-title">Analytics for <%= phone %></h2>
            <div class="page-breadcrumb">Dashboard &rsaquo; Collaborators &rsaquo; <span>Statistics</span></div>
          </div>
          <div id="ip_address" style="font-size: 12px; font-weight: 700; color: var(--text-muted); background: #eee; padding: 4px 12px; border-radius: 20px;">IP Address: Loading...</div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon icon-blue"><i class="fas fa-users"></i></div>
            <div class="stat-info">
              <span class="stat-label">Total Members</span>
              <span class="stat-value totalMember">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-green"><i class="fas fa-trophy"></i></div>
            <div class="stat-info">
              <span class="stat-label">Wins Today</span>
              <span class="stat-value totalWin text-success">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-red"><i class="fas fa-times-circle"></i></div>
            <div class="stat-info">
              <span class="stat-label">Loss Today</span>
              <span class="stat-value totalLoss text-danger">0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-yellow"><i class="fas fa-user-lock"></i></div>
            <div class="stat-info">
              <span class="stat-label">Banned Members</span>
              <span class="stat-value totalMemberFail">0</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon icon-green"><i class="fas fa-arrow-up"></i></div>
            <div class="stat-info">
              <span class="stat-label">Total Deposit</span>
              <span class="stat-value totalRecharge text-success">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-green"><i class="fas fa-calendar-day"></i></div>
            <div class="stat-info">
              <span class="stat-label">Deposit Today</span>
              <span class="stat-value totalRechargeToday">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-yellow"><i class="fas fa-arrow-down"></i></div>
            <div class="stat-info">
              <span class="stat-label">Total Withdraw</span>
              <span class="stat-value totalwithdraw text-warning">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-yellow"><i class="fas fa-calendar-minus"></i></div>
            <div class="stat-info">
              <span class="stat-label">Withdraw Today</span>
              <span class="stat-value totalwithdrawToday">₹0</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon icon-purple"><i class="fas fa-chart-line"></i></div>
            <div class="stat-info">
              <span class="stat-label">Total Commission</span>
              <span class="stat-value totalRoses">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-purple"><i class="fas fa-coins"></i></div>
            <div class="stat-info">
              <span class="stat-label">Comm. Today</span>
              <span class="stat-value totalRosesToday">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-purple"><i class="fas fa-user-friends"></i></div>
            <div class="stat-info">
              <span class="stat-label">F1 Commission</span>
              <span class="stat-value totalRosesF1">₹0</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon icon-purple"><i class="fas fa-sitemap"></i></div>
            <div class="stat-info">
              <span class="stat-label">Team Commission</span>
              <span class="stat-value totalRosesF">₹0</span>
            </div>
          </div>
        </div>

        <!-- Filter -->
        <div class="toolbar">
          <span class="filter-label"><i class="fas fa-calendar-alt"></i> Filter by Date</span>
          <input type="date" id="sort-date" class="date-input">
        </div>

        <!-- Remaining Money Section -->
        <div class="stat-card" style="margin-bottom: 28px; border-left: 4px solid var(--accent);">
          <div class="stat-icon icon-purple"><i class="fas fa-gift"></i></div>
          <div class="stat-info">
            <span class="stat-label">Giftcode Balance</span>
            <span class="stat-value moneyCTV" style="color: var(--accent); font-size: 22px;">₹0</span>
            <span style="font-size: 11px; color: var(--text-muted); font-weight: 600; margin-top: 2px;">Remaining amount to generate giftcodes</span>
          </div>
        </div>

        <!-- Tables Section -->
        <div class="section-card">
          <div class="section-header">
            <h3 class="section-title"><i class="fas fa-ticket-alt" style="color: var(--accent);"></i> Giftcode Details</h3>
          </div>
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Creator</th>
                  <th>Receiver</th>
                  <th>Amount</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody id="list-details-news"></tbody>
            </table>
          </div>
        </div>

        <div class="section-card">
          <div class="section-header">
            <h3 class="section-title"><i class="fas fa-user-plus" style="color: var(--blue);"></i> New Members</h3>
          </div>
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Account</th>
                  <th>Balance</th>
                  <th>Status</th>
                  <th>IP</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody id="list-mem-news"></tbody>
            </table>
          </div>
        </div>

        <div class="section-card">
          <div class="section-header">
            <h3 class="section-title"><i class="fas fa-wallet" style="color: var(--green);"></i> Recharge Today</h3>
          </div>
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Account</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody id="list-recharge-news"></tbody>
            </table>
          </div>
        </div>

        <div class="section-card">
          <div class="section-header">
            <h3 class="section-title"><i class="fas fa-university" style="color: var(--yellow);"></i> Withdrawal Today</h3>
          </div>
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Account</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody id="list-withdraw-news"></tbody>
            </table>
          </div>
        </div>

        <div class="section-card">
          <div class="section-header">
            <h3 class="section-title"><i class="fas fa-exchange-alt" style="color: var(--purple);"></i> Money Flow Details</h3>
          </div>
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Sender</th>
                  <th>Receiver</th>
                  <th>Amount</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody id="financial_details"></tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script src="/plugins/jquery/jquery.min.js"></script>
  <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    function formateT(params) {
      return (params < 10) ? "0" + params : params;
    }

    function timerJoin(params = '') {
      let date = params ? new Date(Number(params)) : new Date();
      let years = formateT(date.getFullYear());
      let months = formateT(date.getMonth() + 1);
      let days = formateT(date.getDate());
      let hours = formateT(date.getHours());
      let minutes = formateT(date.getMinutes());
      let seconds = formateT(date.getSeconds());
      return years + '/' + months + '/' + days + ' ' + hours + ':' + minutes + ':' + seconds;
    }

    const RenderMemberNews = (datas) => {
      let html = datas.length === 0 ? '<tr><td colspan="6" style="padding: 30px; color: var(--text-muted);">No members found.</td></tr>' : '';
      datas.forEach((data) => {
        html += `
          <tr>
            <td>#${data.id_user}</td>
            <td style="color: var(--accent); font-weight: 700;">91${data.phone}</td>
            <td>₹${data.total_money}</td>
            <td><span class="badge ${data.total_money > 0 ? 'bg-success-light' : 'bg-warning-light'}">${data.total_money > 0 ? 'SUCCESS' : 'PENDING'}</span></td>
            <td style="font-size: 11px; color: var(--text-muted);">${data.ip_address}</td>
            <td style="font-size: 11px;">${timerJoin(data.time)}</td>
          </tr>`;
      });
      $("#list-mem-news").html(html);
    }

    const RenderRechargeNews = (datas) => {
      let html = datas.length === 0 ? '<tr><td colspan="5" style="padding: 30px; color: var(--text-muted);">No recharge data today.</td></tr>' : '';
      datas.forEach((data) => {
        html += `
          <tr>
            <td>#${data.id}</td>
            <td style="color: var(--blue);">91${data.phone}</td>
            <td style="color: var(--green); font-weight: 800;">₹${data.money}</td>
            <td><span class="badge bg-success-light">SUCCESS</span></td>
            <td style="font-size: 11px;">${timerJoin(data.time)}</td>
          </tr>`;
      });
      $("#list-recharge-news").html(html);
    }

    const RenderWithdrawNews = (datas) => {
      let html = datas.length === 0 ? '<tr><td colspan="5" style="padding: 30px; color: var(--text-muted);">No withdrawal data today.</td></tr>' : '';
      datas.forEach((data) => {
        html += `
          <tr>
            <td>#${data.id}</td>
            <td style="color: var(--blue);">91${data.phone}</td>
            <td style="color: var(--red); font-weight: 800;">₹${data.money}</td>
            <td><span class="badge bg-success-light">SUCCESS</span></td>
            <td style="font-size: 11px;">${timerJoin(data.time)}</td>
          </tr>`;
      });
      $("#list-withdraw-news").html(html);
    }

    const redenvelopesUsed = (datas) => {
      let html = datas.length === 0 ? '<tr><td colspan="5" style="padding: 30px; color: var(--text-muted);">No giftcodes used yet.</td></tr>' : '';
      datas.forEach((data) => {
        html += `
          <tr>
            <td>#${data.id_redenvelops}</td>
            <td>91${data.phone}</td>
            <td style="color: var(--accent);">91${data.phone_used}</td>
            <td style="color: var(--green); font-weight: 800;">+₹${data.money}</td>
            <td style="font-size: 11px;">${timerJoin(data.time)}</td>
          </tr>`;
      });
      $("#list-details-news").html(html);
    }

    const financial_details = (datas) => {
      let html = datas.length === 0 ? '<tr><td colspan="5" style="padding: 30px; color: var(--text-muted);">No flow details available.</td></tr>' : '';
      datas.forEach((data) => {
        html += `
          <tr>
            <td>#${data.id}</td>
            <td>91${data.phone}</td>
            <td>91${data.phone_used}</td>
            <td style="color: ${data.type == '1' ? 'var(--green)' : 'var(--red)'}; font-weight: 800;">${data.type == '1' ? '+' : '-'} ₹${data.money}</td>
            <td style="font-size: 11px;">${timerJoin(data.time)}</td>
          </tr>`;
      });
      $("#financial_details").html(html);
    }

    // Data Loading
    const loadData = (timeDate = null) => {
      const url = timeDate ? "/admin/manager/infoCtv/select" : "/admin/manager/infoCtv";
      const data = { phone: "<%=phone%>" };
      if (timeDate) data.timeDate = timeDate;

      $.ajax({
        type: "POST",
        url: url,
        data: data,
        dataType: "json",
        success: function (response) {
          RenderMemberNews(response.list_mems || response.list_mems);
          RenderRechargeNews(response.list_recharge_news);
          RenderWithdrawNews(response.list_withdraw_news);
          redenvelopesUsed(response.redenvelopes_used);
          financial_details(response.financial_details_today);

          if (!timeDate) {
            $('.totalMember').text(response.f1 + response.f2 + response.f3 + response.f4);
            $('.totalRoses').text('₹' + (response.datas[0].roses_f + response.datas[0].roses_f1));
            $('.totalRosesToday').text('₹' + response.datas[0].roses_today);
            $('.totalRosesF1').text('₹' + response.datas[0].roses_f1);
            $('.totalRosesF').text('₹' + response.datas[0].roses_f);
            $('#ip_address').text('IP Address: ' + response.datas[0].ip_address);
            $('.totalRecharge').text('₹' + response.total_recharge);
            $('.totalwithdraw').text('₹' + response.total_withdraw);
            $('.totalRechargeToday').text('₹' + response.total_recharge_today);
            $('.totalwithdrawToday').text('₹' + response.total_withdraw_today);
            $('.totalMemberFail').text(response.list_mem_baned);
            $('.totalWin').text(response.win);
            $('.totalLoss').text(response.loss);
            $('.moneyCTV').text('₹' + response.moneyCTV);
          }
        }
      });
    }

    $('#sort-date').change(function () {
      loadData($(this).val());
    });

    loadData();
  </script>
</body>

</html>