          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ gameId: gameId }),
        })
          .then((response) => {
            if (!response.ok) {
              throw new Error("Network response was not ok");
            }
            return response.json();
          })
          .then((response) => {
            if (response.Data) {
              window.location.href = response.Data; // Redirect to the game URL
            } else {
            }
          })
          .catch((error) => {
            console.error("Error playing game:", error);
          });
      }

      function playSpribeGame({ gameName }) {
        if (!window.isLoggedIn) {
          window.location.href = '/login';
          return;
        }
        fetch("/playSpribeGame", {
          method: "POST",
