    <script>


      window.isLoggedIn = false;
      const fetchUser = async () => {
        try {
          const response = await fetch("/api/webapi/GetUserInfo")
          const resJson = await response.json()
          const userData = resJson?.data

          console.log(userData)

          if (userData && userData.money_user !== undefined) {
            window.isLoggedIn = true;
            const formattedMoney = parseFloat(userData.money_user).toFixed(2);
            $("#navbar_balance").text("₹" + formattedMoney);
            $("#navbar_balance_box").show();
          }

          $("#avatar_display").attr("src", `/assets/png/${userData.avatar}`)
          $("#nickname_display").text(userData.name_user)
          $("#nickname_input").val(userData.name_user)
          if (userData.loginTime) {
            const d = new Date(Number(userData.loginTime));

            const formatted =
              `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')} ` +
              `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}:${String(d.getSeconds()).padStart(2, '0')}`;

            $("#LT").text(formatted);
          } else {
            $("#LT").text("Invalid date");
          }
        } catch (error) {
          console.log(error)
        }
      }

      fetchUser();
    </script>


